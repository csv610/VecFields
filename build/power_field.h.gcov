    #####:   51:        pvData.constVectors = tb.project_to_extrinsic(pvData.constSpaces, intConstVector);
    #####:   52:        pvData.wAlignment = Eigen::VectorXd::Constant(pvData.constSpaces.size(),-1.0);
        -:   53:    }
