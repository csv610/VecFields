        -:  630:
        -:  631:// String comparison for narrow or wide strings that can have embedded NUL
        -:  632:// characters.
        -:  633:template <typename StringType>
        -:  634:bool CaseInsensitiveStringEquals(const StringType& s1,
        -:  635:                                 const StringType& s2) {
        -:  636:  // Are the heads equal?
        -:  637:  if (!CaseInsensitiveCStringEquals(s1.c_str(), s2.c_str())) {
        -:  638:    return false;
        -:  639:  }
        -:  640:
        -:  641:  // Skip the equal heads.
        -:  642:  const typename StringType::value_type nul = 0;
        -:  643:  const size_t i1 = s1.find(nul), i2 = s2.find(nul);
        -:  644:
        -:  645:  // Are we at the end of either s1 or s2?
        -:  646:  if (i1 == StringType::npos || i2 == StringType::npos) {
        -:  647:    return i1 == i2;
        -:  648:  }
        -:  649:
        -:  650:  // Are the tails equal?
        -:  651:  return CaseInsensitiveStringEquals(s1.substr(i1 + 1), s2.substr(i2 + 1));
        -:  652:}
