        -: 4569:  return MakePolymorphicMatcher(
        -: 4570:      internal::variant_matcher::VariantMatcher<T>(matcher));
        -: 4571:}
        -: 4572:
        -: 4573:// These macros allow using matchers to check values in Google Test
        -: 4574:// tests.  ASSERT_THAT(value, matcher) and EXPECT_THAT(value, matcher)
        -: 4575:// succeed if and only if the value matches the matcher.  If the assertion
        -: 4576:// fails, the value and the description of the matcher will be printed.
        -: 4577:#define ASSERT_THAT(value, matcher) ASSERT_PRED_FORMAT1(\
        -: 4578:    ::testing::internal::MakePredicateFormatterFromMatcher(matcher), value)
        -: 4579:#define EXPECT_THAT(value, matcher) EXPECT_PRED_FORMAT1(\
        -: 4580:    ::testing::internal::MakePredicateFormatterFromMatcher(matcher), value)
        -: 4581:
