        -: 4178://   EXPECT_THAT(page_ids, Not(Contains(4)));
        -: 4179://
        -: 4180://   ::std::map<int, size_t> page_lengths;
        -: 4181://   page_lengths[1] = 100;
        -: 4182://   EXPECT_THAT(page_lengths,
        -: 4183://               Contains(::std::pair<const int, size_t>(1, 100)));
        -: 4184://
        -: 4185://   const char* user_ids[] = { "joe", "mike", "tom" };
        -: 4186://   EXPECT_THAT(user_ids, Contains(Eq(::std::string("tom"))));
        -: 4187:template <typename M>
