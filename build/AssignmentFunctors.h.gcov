        -:  125:/** \internal
        -:  126:  * \brief Template functor for scalar/packet assignment with swapping
        -:  127:  *
        -:  128:  * It works as follow. For a non-vectorized evaluation loop, we have:
        -:  129:  *   for(i) func(A.coeffRef(i), B.coeff(i));
        -:  130:  * where B is a SwapWrapper expression. The trick is to make SwapWrapper::coeff behaves like a non-const coeffRef.
        -:  131:  * Actually, SwapWrapper might not even be needed since even if B is a plain expression, since it has to be writable
        -:  132:  * B.coeff already returns a const reference to the underlying scalar value.
        -:  133:  * 
        -:  134:  * The case of a vectorized loop is more tricky:
        -:  135:  *   for(i,j) func.assignPacket<A_Align>(&A.coeffRef(i,j), B.packet<B_Align>(i,j));
        -:  136:  * Here, B must be a SwapWrapper whose packet function actually returns a proxy object holding a Scalar*,
        -:  137:  * the actual alignment and Packet type.
        -:  138:  *
        -:  139:  */
        -:  140:template<typename Scalar> struct swap_assign_op {
        -:  141:
       12:  142:  EIGEN_DEVICE_FUNC EIGEN_STRONG_INLINE void assignCoeff(Scalar& a, const Scalar& b) const
        -:  143:  {
        -:  144:#ifdef EIGEN_GPUCC
        -:  145:    // FIXME is there some kind of cuda::swap?
        -:  146:    Scalar t=b; const_cast<Scalar&>(b)=a; a=t;
        -:  147:#else
        -:  148:    using std::swap;
       12:  149:    swap(a,const_cast<Scalar&>(b));
        -:  150:#endif
       12:  151:  }
        -:  152:};
