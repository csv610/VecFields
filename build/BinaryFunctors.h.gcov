        -:  716://---------- binary functors bound to a constant, thus appearing as a unary functor ----------
        -:  717:
        -:  718:// The following two classes permits to turn any binary functor into a unary one with one argument bound to a constant value.
        -:  719:// They are analogues to std::binder1st/binder2nd but with the following differences:
        -:  720://  - they are compatible with packetOp
        -:  721://  - they are portable across C++ versions (the std::binder* are deprecated in C++11)
        -:  722:template<typename BinaryOp> struct bind1st_op : BinaryOp {
        -:  723:
        -:  724:  typedef typename BinaryOp::first_argument_type  first_argument_type;
        -:  725:  typedef typename BinaryOp::second_argument_type second_argument_type;
        -:  726:  typedef typename BinaryOp::result_type          result_type;
        -:  727:
        -:  728:  EIGEN_DEVICE_FUNC explicit bind1st_op(const first_argument_type &val) : m_value(val) {}
        -:  729:
        -:  730:  EIGEN_DEVICE_FUNC EIGEN_STRONG_INLINE const result_type operator() (const second_argument_type& b) const { return BinaryOp::operator()(m_value,b); }
        -:  731:
        -:  732:  template<typename Packet>
        -:  733:  EIGEN_DEVICE_FUNC EIGEN_STRONG_INLINE const Packet packetOp(const Packet& b) const
        -:  734:  { return BinaryOp::packetOp(internal::pset1<Packet>(m_value), b); }
        -:  735:
        -:  736:  first_argument_type m_value;
        -:  737:};
        -:  738:template<typename BinaryOp> struct functor_traits<bind1st_op<BinaryOp> > : functor_traits<BinaryOp> {};
        -:  739:
        -:  740:
        -:  741:template<typename BinaryOp> struct bind2nd_op : BinaryOp {
        -:  742:
        -:  743:  typedef typename BinaryOp::first_argument_type  first_argument_type;
        -:  744:  typedef typename BinaryOp::second_argument_type second_argument_type;
        -:  745:  typedef typename BinaryOp::result_type          result_type;
        -:  746:
        -:  747:  EIGEN_DEVICE_FUNC explicit bind2nd_op(const second_argument_type &val) : m_value(val) {}
        -:  748:
        -:  749:  EIGEN_DEVICE_FUNC EIGEN_STRONG_INLINE const result_type operator() (const first_argument_type& a) const { return BinaryOp::operator()(a,m_value); }
        -:  750:
        -:  751:  template<typename Packet>
        -:  752:  EIGEN_DEVICE_FUNC EIGEN_STRONG_INLINE const Packet packetOp(const Packet& a) const
        -:  753:  { return BinaryOp::packetOp(a,internal::pset1<Packet>(m_value)); }
        -:  754:
        -:  755:  second_argument_type m_value;
        -:  756:};
        -:  757:template<typename BinaryOp> struct functor_traits<bind2nd_op<BinaryOp> > : functor_traits<BinaryOp> {};
        -:  758:
        -:  759:
        -:  760:} // end namespace internal
        -:  761:
        -:  762:} // end namespace Eigen
