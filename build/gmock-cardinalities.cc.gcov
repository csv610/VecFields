        -:   93:// Formats "n times" in a human-friendly way.
    #####:   94:inline std::string FormatTimes(int n) {
    #####:   95:  if (n == 1) {
    #####:   96:    return "once";
    #####:   97:  } else if (n == 2) {
    #####:   98:    return "twice";
        -:   99:  } else {
    #####:  100:    std::stringstream ss;
    #####:  101:    ss << n << " times";
    #####:  102:    return ss.str();
    #####:  103:  }
    #####:  104:}
