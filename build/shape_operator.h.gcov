        4:   34:static std::unordered_map<int, std::set<int>> build_adjacency(const Eigen::MatrixXi& EV) {
        4:   35:    std::unordered_map<int, std::set<int>> adj;
     4234:   36:    for (int i = 0; i < EV.rows(); ++i) {
     4230:   37:        int v0 = EV(i, 0);
     4230:   38:        int v1 = EV(i, 1);
     4230:   39:        adj[v0].insert(v1);
     4230:   40:        adj[v1].insert(v0);
     4230:   41:    }
        4:   42:    return adj;
        4:   43:}
