        -:   42:template<typename Packet> EIGEN_STRONG_INLINE EIGEN_DEVICE_FUNC
        -:   43:Packet pfrexp_generic(const Packet& a, Packet& exponent) {
        -:   44:  typedef typename unpacket_traits<Packet>::type Scalar;
        -:   45:  typedef typename make_unsigned<typename make_integer<Scalar>::type>::type ScalarUI;
        -:   46:  static constexpr int
        -:   47:    TotalBits = sizeof(Scalar) * CHAR_BIT,
        -:   48:    MantissaBits = numext::numeric_limits<Scalar>::digits - 1,
        -:   49:    ExponentBits = TotalBits - MantissaBits - 1;
        -:   50:
        -:   51:  EIGEN_CONSTEXPR ScalarUI scalar_sign_mantissa_mask =
        -:   52:      ~(((ScalarUI(1) << ExponentBits) - ScalarUI(1)) << MantissaBits); // ~0x7f800000
        -:   53:  const Packet sign_mantissa_mask = pset1frombits<Packet>(static_cast<ScalarUI>(scalar_sign_mantissa_mask));
        -:   54:  const Packet half = pset1<Packet>(Scalar(0.5));
        -:   55:  const Packet zero = pzero(a);
        -:   56:  const Packet normal_min = pset1<Packet>((numext::numeric_limits<Scalar>::min)()); // Minimum normal value, 2^-126
        -:   57:
        -:   58:  // To handle denormals, normalize by multiplying by 2^(int(MantissaBits)+1).
        -:   59:  const Packet is_denormal = pcmp_lt(pabs(a), normal_min);
        -:   60:  EIGEN_CONSTEXPR ScalarUI scalar_normalization_offset = ScalarUI(MantissaBits + 1); // 24
        -:   61:  // The following cannot be constexpr because bfloat16(uint16_t) is not constexpr.
        -:   62:  const Scalar scalar_normalization_factor = Scalar(ScalarUI(1) << int(scalar_normalization_offset)); // 2^24
        -:   63:  const Packet normalization_factor = pset1<Packet>(scalar_normalization_factor);
        -:   64:  const Packet normalized_a = pselect(is_denormal, pmul(a, normalization_factor), a);
        -:   65:
        -:   66:  // Determine exponent offset: -126 if normal, -126-24 if denormal
        -:   67:  const Scalar scalar_exponent_offset = -Scalar((ScalarUI(1)<<(ExponentBits-1)) - ScalarUI(2)); // -126
        -:   68:  Packet exponent_offset = pset1<Packet>(scalar_exponent_offset);
        -:   69:  const Packet normalization_offset = pset1<Packet>(-Scalar(scalar_normalization_offset)); // -24
        -:   70:  exponent_offset = pselect(is_denormal, padd(exponent_offset, normalization_offset), exponent_offset);
        -:   71:
        -:   72:  // Determine exponent and mantissa from normalized_a.
        -:   73:  exponent = pfrexp_generic_get_biased_exponent(normalized_a);
        -:   74:  // Zero, Inf and NaN return 'a' unmodified, exponent is zero
        -:   75:  // (technically the exponent is unspecified for inf/NaN, but GCC/Clang set it to zero)
        -:   76:  const Scalar scalar_non_finite_exponent = Scalar((ScalarUI(1) << ExponentBits) - ScalarUI(1));  // 255
        -:   77:  const Packet non_finite_exponent = pset1<Packet>(scalar_non_finite_exponent);
        -:   78:  const Packet is_zero_or_not_finite = por(pcmp_eq(a, zero), pcmp_eq(exponent, non_finite_exponent));
