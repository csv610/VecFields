        -:  408:{
        -:  409:  const Packet cst_zero   = pset1<Packet>(0.0f);
        -:  410:  const Packet cst_one    = pset1<Packet>(1.0f);
        -:  411:  const Packet cst_half   = pset1<Packet>(0.5f);
        -:  412:  const Packet cst_exp_hi = pset1<Packet>(88.723f);
        -:  413:  const Packet cst_exp_lo = pset1<Packet>(-104.f);
        -:  414:
        -:  415:  const Packet cst_cephes_LOG2EF = pset1<Packet>(1.44269504088896341f);
        -:  416:  const Packet cst_p2 = pset1<Packet>(0.49999988079071044921875f);
        -:  417:  const Packet cst_p3 = pset1<Packet>(0.16666518151760101318359375f);
        -:  418:  const Packet cst_p4 = pset1<Packet>(4.166965186595916748046875e-2f);
        -:  419:  const Packet cst_p5 = pset1<Packet>(8.36894474923610687255859375e-3f);
        -:  420:  const Packet cst_p6 = pset1<Packet>(1.37449637986719608306884765625e-3f);
        -:  421:
        -:  422:  // Clamp x.
        -:  423:  Packet zero_mask = pcmp_lt(_x, cst_exp_lo);
        -:  424:  Packet x = pmin(_x, cst_exp_hi);
        -:  425:
        -:  426:  // Express exp(x) as exp(m*ln(2) + r), start by extracting
        -:  427:  // m = floor(x/ln(2) + 0.5).
        -:  428:  Packet m = pfloor(pmadd(x, cst_cephes_LOG2EF, cst_half));
        -:  429:
        -:  430:  // Get r = x - m*ln(2). If no FMA instructions are available, m*ln(2) is
        -:  431:  // subtracted out in two parts, m*C1+m*C2 = m*ln(2), to avoid accumulating
        -:  432:  // truncation errors.
        -:  433:  const Packet cst_cephes_exp_C1 = pset1<Packet>(-0.693359375f);
        -:  434:  const Packet cst_cephes_exp_C2 = pset1<Packet>(2.12194440e-4f);
        -:  435:  Packet r = pmadd(m, cst_cephes_exp_C1, x);
        -:  436:  r = pmadd(m, cst_cephes_exp_C2, r);
        -:  437:
        -:  438:  // Evaluate the 6th order polynomial approximation to exp(r)
        -:  439:  // with r in the interval [-ln(2)/2;ln(2)/2].
        -:  440:  const Packet r2 = pmul(r, r);
        -:  441:  Packet p_even = pmadd(r2, cst_p6, cst_p4);
        -:  442:  const Packet p_odd = pmadd(r2, cst_p5, cst_p3);
        -:  443:  p_even = pmadd(r2, p_even, cst_p2);
        -:  444:  const Packet p_low = padd(r, cst_one);
        -:  445:  Packet y = pmadd(r, p_odd, p_even);
        -:  446:  y = pmadd(r2, y, p_low);
        -:  447:
        -:  448:  // Return 2^m * exp(r).
        -:  449:  // TODO: replace pldexp with faster implementation since y in [-1, 1).
        -:  450:  return pselect(zero_mask, cst_zero, pmax(pldexp(y,m), _x));
        -:  451:}
