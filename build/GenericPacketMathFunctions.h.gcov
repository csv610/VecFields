        -:  574:  // Round to nearest: add 0.5 and extract integral part.
        -:  575:  uint64_t q = (p + zero_dot_five) >> 62;
        -:  576:  *quadrant = int(q);
        -:  577:  // Now it remains to compute "r = x - q*pi/2" with high accuracy,
        -:  578:  // since we have p=x/(pi/2) with high accuracy, we can more efficiently compute r as:
        -:  579:  //   r = (p-q)*pi/2,
        -:  580:  // where the product can be be carried out with sufficient accuracy using double precision.
        -:  581:  p -= q<<62;
        -:  582:  return float(double(int64_t(p)) * pio2_62);
