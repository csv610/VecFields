        -:   84:// Safely applies ldexp, correctly handles overflows, underflows and denormals.
        -:   85:// Assumes IEEE floating point format.
        -:   86:template<typename Packet> EIGEN_STRONG_INLINE EIGEN_DEVICE_FUNC
        -:   87:Packet pldexp_generic(const Packet& a, const Packet& exponent) {
        -:   88:  // We want to return a * 2^exponent, allowing for all possible integer
        -:   89:  // exponents without overflowing or underflowing in intermediate
        -:   90:  // computations.
        -:   91:  //
        -:   92:  // Since 'a' and the output can be denormal, the maximum range of 'exponent'
        -:   93:  // to consider for a float is:
        -:   94:  //   -255-23 -> 255+23
        -:   95:  // Below -278 any finite float 'a' will become zero, and above +278 any
        -:   96:  // finite float will become inf, including when 'a' is the smallest possible 
        -:   97:  // denormal.
        -:   98:  //
        -:   99:  // Unfortunately, 2^(278) cannot be represented using either one or two
        -:  100:  // finite normal floats, so we must split the scale factor into at least
        -:  101:  // three parts. It turns out to be faster to split 'exponent' into four
        -:  102:  // factors, since [exponent>>2] is much faster to compute that [exponent/3].
        -:  103:  //
        -:  104:  // Set e = min(max(exponent, -278), 278);
        -:  105:  //     b = floor(e/4);
        -:  106:  //   out = ((((a * 2^(b)) * 2^(b)) * 2^(b)) * 2^(e-3*b))
        -:  107:  //
        -:  108:  // This will avoid any intermediate overflows and correctly handle 0, inf,
        -:  109:  // NaN cases.
        -:  110:  typedef typename unpacket_traits<Packet>::integer_packet PacketI;
        -:  111:  typedef typename unpacket_traits<Packet>::type Scalar;
        -:  112:  typedef typename unpacket_traits<PacketI>::type ScalarI;
        -:  113:  static constexpr int
        -:  114:    TotalBits = sizeof(Scalar) * CHAR_BIT,
        -:  115:    MantissaBits = numext::numeric_limits<Scalar>::digits - 1,
        -:  116:    ExponentBits = TotalBits - MantissaBits - 1;
        -:  117:
        -:  118:  const Packet max_exponent = pset1<Packet>(Scalar((ScalarI(1)<<ExponentBits) + ScalarI(MantissaBits - 1)));  // 278
        -:  119:  const PacketI bias = pset1<PacketI>((ScalarI(1)<<(ExponentBits-1)) - ScalarI(1));  // 127
        -:  120:  const PacketI e = pcast<Packet, PacketI>(pmin(pmax(exponent, pnegate(max_exponent)), max_exponent));
        -:  121:  PacketI b = parithmetic_shift_right<2>(e); // floor(e/4);
        -:  122:  Packet c = preinterpret<Packet>(plogical_shift_left<MantissaBits>(padd(b, bias)));  // 2^b
        -:  123:  Packet out = pmul(pmul(pmul(a, c), c), c);  // a * 2^(3b)
        -:  124:  b = psub(psub(psub(e, b), b), b); // e - 3b
        -:  125:  c = preinterpret<Packet>(plogical_shift_left<MantissaBits>(padd(b, bias)));  // 2^(e-3*b)
        -:  126:  out = pmul(out, c);
        -:  127:  return out;
        -:  128:}
