        -:  522:// The following code is inspired by the following stack-overflow answer:
        -:  523://   https://stackoverflow.com/questions/30463616/payne-hanek-algorithm-implementation-in-c/30465751#30465751
        -:  524:// It has been largely optimized:
        -:  525://  - By-pass calls to frexp.
        -:  526://  - Aligned loads of required 96 bits of 2/pi. This is accomplished by
        -:  527://    (1) balancing the mantissa and exponent to the required bits of 2/pi are
        -:  528://    aligned on 8-bits, and (2) replicating the storage of the bits of 2/pi.
        -:  529://  - Avoid a branch in rounding and extraction of the remaining fractional part.
        -:  530:// Overall, I measured a speed up higher than x2 on x86-64.
        -:  531:inline float trig_reduce_huge (float xf, Eigen::numext::int32_t *quadrant)
        -:  532:{
        -:  533:  using Eigen::numext::int32_t;
        -:  534:  using Eigen::numext::uint32_t;
        -:  535:  using Eigen::numext::int64_t;
        -:  536:  using Eigen::numext::uint64_t;
        -:  537:
        -:  538:  const double pio2_62 = 3.4061215800865545e-19;    // pi/2 * 2^-62
        -:  539:  const uint64_t zero_dot_five = uint64_t(1) << 61; // 0.5 in 2.62-bit fixed-point format
        -:  540:
        -:  541:  // 192 bits of 2/pi for Payne-Hanek reduction
        -:  542:  // Bits are introduced by packet of 8 to enable aligned reads.
        -:  543:  static const uint32_t two_over_pi [] = 
        -:  544:  {
        -:  545:    0x00000028, 0x000028be, 0x0028be60, 0x28be60db,
        -:  546:    0xbe60db93, 0x60db9391, 0xdb939105, 0x9391054a,
        -:  547:    0x91054a7f, 0x054a7f09, 0x4a7f09d5, 0x7f09d5f4,
        -:  548:    0x09d5f47d, 0xd5f47d4d, 0xf47d4d37, 0x7d4d3770,
        -:  549:    0x4d377036, 0x377036d8, 0x7036d8a5, 0x36d8a566,
        -:  550:    0xd8a5664f, 0xa5664f10, 0x664f10e4, 0x4f10e410,
        -:  551:    0x10e41000, 0xe4100000
        -:  552:  };
        -:  553:  
        -:  554:  uint32_t xi = numext::bit_cast<uint32_t>(xf);
        -:  555:  // Below, -118 = -126 + 8.
        -:  556:  //   -126 is to get the exponent,
        -:  557:  //   +8 is to enable alignment of 2/pi's bits on 8 bits.
        -:  558:  // This is possible because the fractional part of x as only 24 meaningful bits.
        -:  559:  uint32_t e = (xi >> 23) - 118;
        -:  560:  // Extract the mantissa and shift it to align it wrt the exponent
        -:  561:  xi = ((xi & 0x007fffffu)| 0x00800000u) << (e & 0x7);
        -:  562:
        -:  563:  uint32_t i = e >> 3;
        -:  564:  uint32_t twoopi_1  = two_over_pi[i-1];
        -:  565:  uint32_t twoopi_2  = two_over_pi[i+3];
        -:  566:  uint32_t twoopi_3  = two_over_pi[i+7];
        -:  567:
        -:  568:  // Compute x * 2/pi in 2.62-bit fixed-point format.
        -:  569:  uint64_t p;
        -:  570:  p = uint64_t(xi) * twoopi_3;
        -:  571:  p = uint64_t(xi) * twoopi_2 + (p >> 32);
        -:  572:  p = (uint64_t(xi * twoopi_1) << 32) + p;
