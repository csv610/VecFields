        -:  443:
        -:  444:/** \defgroup matrixtypedefs Global matrix typedefs
        -:  445:  *
        -:  446:  * \ingroup Core_Module
        -:  447:  *
        -:  448:  * %Eigen defines several typedef shortcuts for most common matrix and vector types.
        -:  449:  *
        -:  450:  * The general patterns are the following:
        -:  451:  *
        -:  452:  * \c MatrixSizeType where \c Size can be \c 2,\c 3,\c 4 for fixed size square matrices or \c X for dynamic size,
        -:  453:  * and where \c Type can be \c i for integer, \c f for float, \c d for double, \c cf for complex float, \c cd
        -:  454:  * for complex double.
        -:  455:  *
        -:  456:  * For example, \c Matrix3d is a fixed-size 3x3 matrix type of doubles, and \c MatrixXf is a dynamic-size matrix of floats.
        -:  457:  *
        -:  458:  * There are also \c VectorSizeType and \c RowVectorSizeType which are self-explanatory. For example, \c Vector4cf is
        -:  459:  * a fixed-size vector of 4 complex floats.
        -:  460:  *
        -:  461:  * With \cpp11, template alias are also defined for common sizes.
        -:  462:  * They follow the same pattern as above except that the scalar type suffix is replaced by a
        -:  463:  * template parameter, i.e.:
        -:  464:  *   - `MatrixSize<Type>` where `Size` can be \c 2,\c 3,\c 4 for fixed size square matrices or \c X for dynamic size.
        -:  465:  *   - `MatrixXSize<Type>` and `MatrixSizeX<Type>` where `Size` can be \c 2,\c 3,\c 4 for hybrid dynamic/fixed matrices.
        -:  466:  *   - `VectorSize<Type>` and `RowVectorSize<Type>` for column and row vectors.
        -:  467:  *
        -:  468:  * With \cpp11, you can also use fully generic column and row vector types: `Vector<Type,Size>` and `RowVector<Type,Size>`.
        -:  469:  *
        -:  470:  * \sa class Matrix
        -:  471:  */
        -:  472:
        -:  473:#define EIGEN_MAKE_TYPEDEFS(Type, TypeSuffix, Size, SizeSuffix)   \
        -:  474:/** \ingroup matrixtypedefs */                                    \
        -:  475:/** \brief `Size`&times;`Size` matrix of type `Type`. */          \
        -:  476:typedef Matrix<Type, Size, Size> Matrix##SizeSuffix##TypeSuffix;  \
        -:  477:/** \ingroup matrixtypedefs */                                    \
        -:  478:/** \brief `Size`&times;`1` vector of type `Type`. */             \
        -:  479:typedef Matrix<Type, Size, 1>    Vector##SizeSuffix##TypeSuffix;  \
        -:  480:/** \ingroup matrixtypedefs */                                    \
        -:  481:/** \brief `1`&times;`Size` vector of type `Type`. */             \
        -:  482:typedef Matrix<Type, 1, Size>    RowVector##SizeSuffix##TypeSuffix;
        -:  483:
        -:  484:#define EIGEN_MAKE_FIXED_TYPEDEFS(Type, TypeSuffix, Size)         \
        -:  485:/** \ingroup matrixtypedefs */                                    \
        -:  486:/** \brief `Size`&times;`Dynamic` matrix of type `Type`. */       \
        -:  487:typedef Matrix<Type, Size, Dynamic> Matrix##Size##X##TypeSuffix;  \
        -:  488:/** \ingroup matrixtypedefs */                                    \
        -:  489:/** \brief `Dynamic`&times;`Size` matrix of type `Type`. */       \
        -:  490:typedef Matrix<Type, Dynamic, Size> Matrix##X##Size##TypeSuffix;
        -:  491:
        -:  492:#define EIGEN_MAKE_TYPEDEFS_ALL_SIZES(Type, TypeSuffix) \
        -:  493:EIGEN_MAKE_TYPEDEFS(Type, TypeSuffix, 2, 2) \
        -:  494:EIGEN_MAKE_TYPEDEFS(Type, TypeSuffix, 3, 3) \
        -:  495:EIGEN_MAKE_TYPEDEFS(Type, TypeSuffix, 4, 4) \
        -:  496:EIGEN_MAKE_TYPEDEFS(Type, TypeSuffix, Dynamic, X) \
        -:  497:EIGEN_MAKE_FIXED_TYPEDEFS(Type, TypeSuffix, 2) \
        -:  498:EIGEN_MAKE_FIXED_TYPEDEFS(Type, TypeSuffix, 3) \
        -:  499:EIGEN_MAKE_FIXED_TYPEDEFS(Type, TypeSuffix, 4)
        -:  500:
        -:  501:EIGEN_MAKE_TYPEDEFS_ALL_SIZES(int,                  i)
        -:  502:EIGEN_MAKE_TYPEDEFS_ALL_SIZES(float,                f)
        -:  503:EIGEN_MAKE_TYPEDEFS_ALL_SIZES(double,               d)
        -:  504:EIGEN_MAKE_TYPEDEFS_ALL_SIZES(std::complex<float>,  cf)
        -:  505:EIGEN_MAKE_TYPEDEFS_ALL_SIZES(std::complex<double>, cd)
        -:  506:
        -:  507:#undef EIGEN_MAKE_TYPEDEFS_ALL_SIZES
        -:  508:#undef EIGEN_MAKE_TYPEDEFS
        -:  509:#undef EIGEN_MAKE_FIXED_TYPEDEFS
        -:  510:
        -:  511:#define EIGEN_MAKE_TYPEDEFS(Size, SizeSuffix)                        \
        -:  512:/** \ingroup matrixtypedefs */                                       \
        -:  513:/** \brief \cpp11 `Size`&times;`Size` matrix of type `Type`.*/       \
        -:  514:template <typename Type>                                             \
        -:  515:using Matrix##SizeSuffix = Matrix<Type, Size, Size>;                 \
        -:  516:/** \ingroup matrixtypedefs */                                       \
        -:  517:/** \brief \cpp11 `Size`&times;`1` vector of type `Type`.*/          \
        -:  518:template <typename Type>                                             \
        -:  519:using Vector##SizeSuffix = Matrix<Type, Size, 1>;                    \
        -:  520:/** \ingroup matrixtypedefs */                                       \
        -:  521:/** \brief \cpp11 `1`&times;`Size` vector of type `Type`.*/          \
        -:  522:template <typename Type>                                             \
        -:  523:using RowVector##SizeSuffix = Matrix<Type, 1, Size>;
        -:  524:
        -:  525:#define EIGEN_MAKE_FIXED_TYPEDEFS(Size)                            \
        -:  526:/** \ingroup matrixtypedefs */                                     \
        -:  527:/** \brief \cpp11 `Size`&times;`Dynamic` matrix of type `Type` */  \
        -:  528:template <typename Type>                                           \
        -:  529:using Matrix##Size##X = Matrix<Type, Size, Dynamic>;               \
        -:  530:/** \ingroup matrixtypedefs */                                     \
        -:  531:/** \brief \cpp11 `Dynamic`&times;`Size` matrix of type `Type`. */ \
        -:  532:template <typename Type>                                           \
        -:  533:using Matrix##X##Size = Matrix<Type, Dynamic, Size>;
        -:  534:
        -:  535:EIGEN_MAKE_TYPEDEFS(2, 2)
        -:  536:EIGEN_MAKE_TYPEDEFS(3, 3)
        -:  537:EIGEN_MAKE_TYPEDEFS(4, 4)
        -:  538:EIGEN_MAKE_TYPEDEFS(Dynamic, X)
        -:  539:EIGEN_MAKE_FIXED_TYPEDEFS(2)
        -:  540:EIGEN_MAKE_FIXED_TYPEDEFS(3)
        -:  541:EIGEN_MAKE_FIXED_TYPEDEFS(4)
        -:  542:
        -:  543:/** \ingroup matrixtypedefs
        -:  544:  * \brief \cpp11 `Size`&times;`1` vector of type `Type`. */
        -:  545:template <typename Type, int Size>
        -:  546:using Vector = Matrix<Type, Size, 1>;
        -:  547:
        -:  548:/** \ingroup matrixtypedefs
        -:  549:  * \brief \cpp11 `1`&times;`Size` vector of type `Type`. */
        -:  550:template <typename Type, int Size>
        -:  551:using RowVector = Matrix<Type, 1, Size>;
        -:  552:
        -:  553:#undef EIGEN_MAKE_TYPEDEFS
        -:  554:#undef EIGEN_MAKE_FIXED_TYPEDEFS
        -:  555:
        -:  556:} // end namespace Eigen
