        -:   61:  * x = dec.solve(b);             // solve A   * x = b
        -:   62:  * x = dec.transpose().solve(b); // solve A^T * x = b
        -:   63:  * x = dec.adjoint().solve(b);   // solve A'  * x = b
        -:   64:  * \endcode
        -:   65:  *
        -:   66:  * \warning Currently, any other usage of transpose() and adjoint() are not supported and will produce compilation errors.
        -:   67:  *
