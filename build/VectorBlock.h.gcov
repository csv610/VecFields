        -:   71:    EIGEN_DENSE_PUBLIC_INTERFACE(VectorBlock)
        -:   72:    EIGEN_STATIC_ASSERT_VECTOR_ONLY(VectorBlock)
     6484:   73:    EIGEN_INHERIT_ASSIGNMENT_OPERATORS(VectorBlock)
