        -: 1818:/****************************************************************************
        -: 1819:* Implementation of fuzzy comparisons                                       *
        -: 1820:****************************************************************************/
        -: 1821:
        -: 1822:template<typename Scalar,
        -: 1823:         bool IsComplex,
        -: 1824:         bool IsInteger>
        -: 1825:struct scalar_fuzzy_default_impl {};
        -: 1826:
        -: 1827:template<typename Scalar>
        -: 1828:struct scalar_fuzzy_default_impl<Scalar, false, false>
        -: 1829:{
        -: 1830:  typedef typename NumTraits<Scalar>::Real RealScalar;
        -: 1831:  template<typename OtherScalar> EIGEN_DEVICE_FUNC
        -: 1832:  static inline bool isMuchSmallerThan(const Scalar& x, const OtherScalar& y, const RealScalar& prec)
        -: 1833:  {
        -: 1834:    return numext::abs(x) <= numext::abs(y) * prec;
        -: 1835:  }
        -: 1836:  EIGEN_DEVICE_FUNC
        -: 1837:  static inline bool isApprox(const Scalar& x, const Scalar& y, const RealScalar& prec)
        -: 1838:  {
        -: 1839:    return numext::abs(x - y) <= numext::mini(numext::abs(x), numext::abs(y)) * prec;
        -: 1840:  }
        -: 1841:  EIGEN_DEVICE_FUNC
        -: 1842:  static inline bool isApproxOrLessThan(const Scalar& x, const Scalar& y, const RealScalar& prec)
        -: 1843:  {
        -: 1844:    return x <= y || isApprox(x, y, prec);
        -: 1845:  }
        -: 1846:};
        -: 1847:
        -: 1848:template<typename Scalar>
        -: 1849:struct scalar_fuzzy_default_impl<Scalar, false, true>
        -: 1850:{
        -: 1851:  typedef typename NumTraits<Scalar>::Real RealScalar;
        -: 1852:  template<typename OtherScalar> EIGEN_DEVICE_FUNC
        -: 1853:  static inline bool isMuchSmallerThan(const Scalar& x, const Scalar&, const RealScalar&)
        -: 1854:  {
        -: 1855:    return x == Scalar(0);
        -: 1856:  }
        -: 1857:  EIGEN_DEVICE_FUNC
        -: 1858:  static inline bool isApprox(const Scalar& x, const Scalar& y, const RealScalar&)
        -: 1859:  {
        -: 1860:    return x == y;
        -: 1861:  }
        -: 1862:  EIGEN_DEVICE_FUNC
        -: 1863:  static inline bool isApproxOrLessThan(const Scalar& x, const Scalar& y, const RealScalar&)
        -: 1864:  {
        -: 1865:    return x <= y;
        -: 1866:  }
        -: 1867:};
        -: 1868:
        -: 1869:template<typename Scalar>
        -: 1870:struct scalar_fuzzy_default_impl<Scalar, true, false>
        -: 1871:{
        -: 1872:  typedef typename NumTraits<Scalar>::Real RealScalar;
        -: 1873:  template<typename OtherScalar> EIGEN_DEVICE_FUNC
        -: 1874:  static inline bool isMuchSmallerThan(const Scalar& x, const OtherScalar& y, const RealScalar& prec)
        -: 1875:  {
        -: 1876:    return numext::abs2(x) <= numext::abs2(y) * prec * prec;
        -: 1877:  }
        -: 1878:  EIGEN_DEVICE_FUNC
        -: 1879:  static inline bool isApprox(const Scalar& x, const Scalar& y, const RealScalar& prec)
        -: 1880:  {
        -: 1881:    return numext::abs2(x - y) <= numext::mini(numext::abs2(x), numext::abs2(y)) * prec * prec;
        -: 1882:  }
        -: 1883:};
        -: 1884:
        -: 1885:template<typename Scalar>
        -: 1886:struct scalar_fuzzy_impl : scalar_fuzzy_default_impl<Scalar, NumTraits<Scalar>::IsComplex, NumTraits<Scalar>::IsInteger> {};
        -: 1887:
        -: 1888:template<typename Scalar, typename OtherScalar> EIGEN_DEVICE_FUNC
        -: 1889:inline bool isMuchSmallerThan(const Scalar& x, const OtherScalar& y,
        -: 1890:                              const typename NumTraits<Scalar>::Real &precision = NumTraits<Scalar>::dummy_precision())
        -: 1891:{
        -: 1892:  return scalar_fuzzy_impl<Scalar>::template isMuchSmallerThan<OtherScalar>(x, y, precision);
        -: 1893:}
        -: 1894:
        -: 1895:template<typename Scalar> EIGEN_DEVICE_FUNC
        -: 1896:inline bool isApprox(const Scalar& x, const Scalar& y,
        -: 1897:                     const typename NumTraits<Scalar>::Real &precision = NumTraits<Scalar>::dummy_precision())
        -: 1898:{
        -: 1899:  return scalar_fuzzy_impl<Scalar>::isApprox(x, y, precision);
        -: 1900:}
        -: 1901:
        -: 1902:template<typename Scalar> EIGEN_DEVICE_FUNC
        -: 1903:inline bool isApproxOrLessThan(const Scalar& x, const Scalar& y,
        -: 1904:                               const typename NumTraits<Scalar>::Real &precision = NumTraits<Scalar>::dummy_precision())
        -: 1905:{
        -: 1906:  return scalar_fuzzy_impl<Scalar>::isApproxOrLessThan(x, y, precision);
        -: 1907:}
