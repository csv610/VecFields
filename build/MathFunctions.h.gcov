        -: 1923:  }
        -: 1924:};
        -: 1925:
        -: 1926:template<> struct scalar_fuzzy_impl<bool>
        -: 1927:{
        -: 1928:  typedef bool RealScalar;
        -: 1929:
        -: 1930:  template<typename OtherScalar> EIGEN_DEVICE_FUNC
        -: 1931:  static inline bool isMuchSmallerThan(const bool& x, const bool&, const bool&)
        -: 1932:  {
        -: 1933:    return !x;
        -: 1934:  }
        -: 1935:
        -: 1936:  EIGEN_DEVICE_FUNC
        -: 1937:  static inline bool isApprox(bool x, bool y, bool)
        -: 1938:  {
        -: 1939:    return x == y;
        -: 1940:  }
        -: 1941:
        -: 1942:  EIGEN_DEVICE_FUNC
        -: 1943:  static inline bool isApproxOrLessThan(const bool& x, const bool& y, const bool&)
        -: 1944:  {
        -: 1945:    return (!x) || y;
        -: 1946:  }
        -: 1947:
        -: 1948:};
        -: 1949:
        -: 1950:} // end namespace internal
        -: 1951:
        -: 1952:// Default implementations that rely on other numext implementations
        -: 1953:namespace internal {
        -: 1954:
        -: 1955:// Specialization for complex types that are not supported by std::expm1.
        -: 1956:template <typename RealScalar>
        -: 1957:struct expm1_impl<std::complex<RealScalar> > {
        -: 1958:  EIGEN_STATIC_ASSERT_NON_INTEGER(RealScalar)
        -: 1959:
        -: 1960:  EIGEN_DEVICE_FUNC static inline std::complex<RealScalar> run(
        -: 1961:      const std::complex<RealScalar>& x) {
        -: 1962:    RealScalar xr = x.real();
        -: 1963:    RealScalar xi = x.imag();
        -: 1964:    // expm1(z) = exp(z) - 1
        -: 1965:    //          = exp(x +  i * y) - 1
        -: 1966:    //          = exp(x) * (cos(y) + i * sin(y)) - 1
        -: 1967:    //          = exp(x) * cos(y) - 1 + i * exp(x) * sin(y)
        -: 1968:    // Imag(expm1(z)) = exp(x) * sin(y)
        -: 1969:    // Real(expm1(z)) = exp(x) * cos(y) - 1
        -: 1970:    //          = exp(x) * cos(y) - 1.
        -: 1971:    //          = expm1(x) + exp(x) * (cos(y) - 1)
        -: 1972:    //          = expm1(x) + exp(x) * (2 * sin(y / 2) ** 2)
        -: 1973:    RealScalar erm1 = numext::expm1<RealScalar>(xr);
        -: 1974:    RealScalar er = erm1 + RealScalar(1.);
        -: 1975:    RealScalar sin2 = numext::sin(xi / RealScalar(2.));
        -: 1976:    sin2 = sin2 * sin2;
        -: 1977:    RealScalar s = numext::sin(xi);
        -: 1978:    RealScalar real_part = erm1 - RealScalar(2.) * er * sin2;
        -: 1979:    return std::complex<RealScalar>(real_part, er * s);
        -: 1980:  }
        -: 1981:};
        -: 1982:
        -: 1983:template<typename T>
        -: 1984:struct rsqrt_impl {
        -: 1985:  EIGEN_DEVICE_FUNC
        -: 1986:  static EIGEN_ALWAYS_INLINE T run(const T& x) {
        -: 1987:    return T(1)/numext::sqrt(x);
        -: 1988:  }
        -: 1989:};
        -: 1990:
        -: 1991:#if defined(EIGEN_GPU_COMPILE_PHASE)
        -: 1992:template<typename T>
        -: 1993:struct conj_impl<std::complex<T>, true>
        -: 1994:{
        -: 1995:  EIGEN_DEVICE_FUNC
        -: 1996:  static inline std::complex<T> run(const std::complex<T>& x)
        -: 1997:  {
        -: 1998:    return std::complex<T>(numext::real(x), -numext::imag(x));
        -: 1999:  }
        -: 2000:};
        -: 2001:#endif
        -: 2002:
        -: 2003:} // end namespace internal
        -: 2004:
        -: 2005:} // end namespace Eigen
        -: 2006:
        -: 2007:#endif // EIGEN_MATHFUNCTIONS_H
