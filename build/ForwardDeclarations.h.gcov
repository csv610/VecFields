        -:   20:template<typename T> struct traits;
        -:   21:
        -:   22:// here we say once and for all that traits<const T> == traits<T>
        -:   23:// When constness must affect traits, it has to be constness on template parameters on which T itself depends.
        -:   24:// For example, traits<Map<const T> > != traits<Map<T> >, but
        -:   25://              traits<const Map<T> > == traits<Map<T> >
        -:   26:template<typename T> struct traits<const T> : traits<T> {};
