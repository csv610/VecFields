        -:   28:template<typename Derived> struct has_direct_access
        -:   29:{
        -:   30:  enum { ret = (traits<Derived>::Flags & DirectAccessBit) ? 1 : 0 };
        -:   31:};
        -:   32:
        -:   33:template<typename Derived> struct accessors_level
        -:   34:{
        -:   35:  enum { has_direct_access = (traits<Derived>::Flags & DirectAccessBit) ? 1 : 0,
        -:   36:         has_write_access = (traits<Derived>::Flags & LvalueBit) ? 1 : 0,
        -:   37:         value = has_direct_access ? (has_write_access ? DirectWriteAccessors : DirectAccessors)
        -:   38:                                   : (has_write_access ? WriteAccessors       : ReadOnlyAccessors)
        -:   39:  };
        -:   40:};
