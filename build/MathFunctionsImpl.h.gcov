        -:  285:template<typename T>
        -:  286:EIGEN_DEVICE_FUNC std::complex<T> complex_rsqrt(const std::complex<T>& z) {
        -:  287:  // Computes the principal reciprocal sqrt of the input.
        -:  288:  //
        -:  289:  // For a complex reciprocal square root of the number z = x + i*y. We want to
        -:  290:  // find real numbers u and v such that
        -:  291:  //    (u + i*v)^2 = 1 / (x + i*y)  <=>
        -:  292:  //    u^2 - v^2 + i*2*u*v = x/|z|^2 - i*v/|z|^2.
        -:  293:  // By equating the real and imaginary parts we get:
        -:  294:  //    u^2 - v^2 = x/|z|^2
        -:  295:  //    2*u*v = y/|z|^2.
        -:  296:  //
        -:  297:  // For x >= 0, this has the numerically stable solution
        -:  298:  //    u = sqrt(0.5 * (x + |z|)) / |z|
        -:  299:  //    v = -y / (2 * u * |z|)
        -:  300:  // and for x < 0,
        -:  301:  //    v = -sign(y) * sqrt(0.5 * (-x + |z|)) / |z|
        -:  302:  //    u = -y / (2 * v * |z|)
        -:  303:  //
        -:  304:  // Letting w = sqrt(0.5 * (|x| + |z|)),
        -:  305:  //   if x == 0: u = w / |z|, v = -sign(y) * w / |z|
        -:  306:  //   if x > 0:  u = w / |z|, v = -y / (2 * w * |z|)
        -:  307:  //   if x < 0:  u = |y| / (2 * w * |z|), v = -sign(y) * w / |z|
        -:  308:
        -:  309:  const T x = numext::real(z);
        -:  310:  const T y = numext::imag(z);
        -:  311:  const T zero = T(0);
        -:  312:
        -:  313:  const T abs_z = numext::hypot(x, y);
        -:  314:  const T w = numext::sqrt(T(0.5) * (numext::abs(x) + abs_z));
        -:  315:  const T woz = w / abs_z;
        -:  316:  // Corner cases consistent with 1/sqrt(z) on gcc/clang.
        -:  317:  return
        -:  318:          numext::is_exactly_zero(abs_z) ? std::complex<T>(NumTraits<T>::infinity(), NumTraits<T>::quiet_NaN())
        -:  319:                                         : ((numext::isinf)(x) || (numext::isinf)(y)) ? std::complex<T>(zero, zero)
        -:  320:      : numext::is_exactly_zero(x) ? std::complex<T>(woz, y < zero ? woz : -woz)
        -:  321:                                   : x > zero ? std::complex<T>(woz, -y / (2 * w * abs_z))
        -:  322:      : std::complex<T>(numext::abs(y) / (2 * w * abs_z), y < zero ? woz : -woz );
        -:  323:}
