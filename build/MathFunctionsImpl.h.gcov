        -:   69:      result.
        -:   70:   2. If a is zero, approx_a_recip must be infinite with the same sign as a.
        -:   71:   3. If a is infinite, approx_a_recip must be zero with the same sign as a.
        -:   72:
        -:   73:   If the preconditions are satisfied, which they are for for the _*_rcp_ps
        -:   74:   instructions on x86, the result has a maximum relative error of 2 ulps,
        -:   75:   and correctly handles zero, infinity, and NaN. Positive denormals are
        -:   76:   treated as zero.
        -:   77:*/
        -:   78:template <typename Packet, int Steps>
        -:   79:struct generic_rsqrt_newton_step {
        -:   80:  static_assert(Steps > 0, "Steps must be at least 1.");
        -:   81:  using Scalar = typename unpacket_traits<Packet>::type;
        -:   82:  EIGEN_DEVICE_FUNC static EIGEN_STRONG_INLINE Packet
        -:   83:  run(const Packet& a, const Packet& approx_rsqrt) {
        -:   84:    constexpr Scalar kMinusHalf = Scalar(-1)/Scalar(2);
        -:   85:    const Packet cst_minus_half = pset1<Packet>(kMinusHalf);
        -:   86:    const Packet cst_minus_one = pset1<Packet>(Scalar(-1));
        -:   87:
        -:   88:    Packet inv_sqrt = approx_rsqrt;
        -:   89:    for (int step = 0; step < Steps; ++step) {
