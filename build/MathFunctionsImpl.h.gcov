        -:  142:    // Do a single step of Newton's iteration for reciprocal square root:
        -:  143:    //   x_{n+1} = x_n * (1.5 + (-0.5 * x_n) * (a * x_n))).
        -:  144:    // The Newton's step is computed this way to avoid over/under-flows.
        -:  145:    Packet rsqrt = pmul(approx_rsqrt, pmadd(pmul(minus_half, approx_rsqrt), pmul(a, approx_rsqrt), one_point_five));
