        -:  172:  const T minus_clamp = pset1<T>(-7.99881172180175781f);
        -:  173:#else
        -:  174:  const T plus_clamp = pset1<T>(7.90531110763549805f);
        -:  175:  const T minus_clamp = pset1<T>(-7.90531110763549805f);
        -:  176:#endif
        -:  177:  const T tiny = pset1<T>(0.0004f);
        -:  178:  const T x = pmax(pmin(a_x, plus_clamp), minus_clamp);
        -:  179:  const T tiny_mask = pcmp_lt(pabs(a_x), tiny);
        -:  180:  // The monomial coefficients of the numerator polynomial (odd).
        -:  181:  const T alpha_1 = pset1<T>(4.89352455891786e-03f);
        -:  182:  const T alpha_3 = pset1<T>(6.37261928875436e-04f);
        -:  183:  const T alpha_5 = pset1<T>(1.48572235717979e-05f);
        -:  184:  const T alpha_7 = pset1<T>(5.12229709037114e-08f);
        -:  185:  const T alpha_9 = pset1<T>(-8.60467152213735e-11f);
        -:  186:  const T alpha_11 = pset1<T>(2.00018790482477e-13f);
        -:  187:  const T alpha_13 = pset1<T>(-2.76076847742355e-16f);
        -:  188:
        -:  189:  // The monomial coefficients of the denominator polynomial (even).
        -:  190:  const T beta_0 = pset1<T>(4.89352518554385e-03f);
        -:  191:  const T beta_2 = pset1<T>(2.26843463243900e-03f);
        -:  192:  const T beta_4 = pset1<T>(1.18534705686654e-04f);
        -:  193:  const T beta_6 = pset1<T>(1.19825839466702e-06f);
        -:  194:
        -:  195:  // Since the polynomials are odd/even, we need x^2.
        -:  196:  const T x2 = pmul(x, x);
        -:  197:
        -:  198:  // Evaluate the numerator polynomial p.
        -:  199:  T p = pmadd(x2, alpha_13, alpha_11);
        -:  200:  p = pmadd(x2, p, alpha_9);
        -:  201:  p = pmadd(x2, p, alpha_7);
        -:  202:  p = pmadd(x2, p, alpha_5);
        -:  203:  p = pmadd(x2, p, alpha_3);
        -:  204:  p = pmadd(x2, p, alpha_1);
        -:  205:  p = pmul(x, p);
        -:  206:
        -:  207:  // Evaluate the denominator polynomial q.
        -:  208:  T q = pmadd(x2, beta_6, beta_4);
        -:  209:  q = pmadd(x2, q, beta_2);
        -:  210:  q = pmadd(x2, q, beta_0);
