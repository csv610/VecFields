        -:   91:      // h_n = (x * inv_sqrt) * inv_sqrt - 1 (so that h_n is nearly 0).
        -:   92:      // inv_sqrt = inv_sqrt - 0.5 * inv_sqrt * h_n
        -:   93:      Packet r2 = pmul(a, inv_sqrt);
        -:   94:      Packet half_r = pmul(inv_sqrt, cst_minus_half);
        -:   95:      Packet h_n = pmadd(r2, inv_sqrt, cst_minus_one);
        -:   96:      inv_sqrt = pmadd(half_r, h_n, inv_sqrt);
        -:   97:    }
