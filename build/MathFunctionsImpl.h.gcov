        -:  148:    }
        -:  149:
        -:  150:    // Return sqrt(x) = x * rsqrt(x) for non-zero finite positive arguments.
        -:  151:    // Return a itself for 0 or +inf, NaN for negative arguments.
        -:  152:    return pselect(return_a, a, pmul(a, rsqrt));
        -:  153:  }
        -:  154:};
