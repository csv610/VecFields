        -:  101:    // 2) zero and infinity were multiplied
        -:  102:    // In either of these cases, return approx_rsqrt
        -:  103:    return pselect(pisnan(inv_sqrt), approx_rsqrt, inv_sqrt);
        -:  104:  }
