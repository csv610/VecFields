        -:   44:/* logic deciding a strategy for unrolling of vectorized paths */
        -:   45:template<typename Func, typename Evaluator>
        -:   46:struct packetwise_redux_traits
        -:   47:{
        -:   48:  enum {
        -:   49:    OuterSize = int(Evaluator::IsRowMajor) ? Evaluator::RowsAtCompileTime : Evaluator::ColsAtCompileTime,
        -:   50:    Cost = OuterSize == Dynamic ? HugeCost
        -:   51:         : OuterSize * Evaluator::CoeffReadCost + (OuterSize-1) * functor_traits<Func>::Cost,
        -:   52:    Unrolling = Cost <= EIGEN_UNROLLING_LIMIT ? CompleteUnrolling : NoUnrolling
        -:   53:  };
        -:   54:
        -:   55:};
