        -:  346:/** \internal In short, it computes int(sqrt(\a Y)) with \a Y an integer.
        -:  347:  * Usage example: \code meta_sqrt<1023>::ret \endcode
        -:  348:  */
        -:  349:template<int Y,
        -:  350:         int InfX = 0,
        -:  351:         int SupX = ((Y==1) ? 1 : Y/2),
        -:  352:         bool Done = ((SupX - InfX) <= 1 || ((SupX * SupX <= Y) && ((SupX + 1) * (SupX + 1) > Y)))>
        -:  353:class meta_sqrt
        -:  354:{
        -:  355:    enum {
        -:  356:      MidX = (InfX+SupX)/2,
        -:  357:      TakeInf = MidX*MidX > Y ? 1 : 0,
        -:  358:      NewInf = int(TakeInf) ? InfX : int(MidX),
        -:  359:      NewSup = int(TakeInf) ? int(MidX) : SupX
        -:  360:    };
        -:  361:  public:
        -:  362:    enum { ret = meta_sqrt<Y,NewInf,NewSup>::ret };
        -:  363:};
        -:  364:
        -:  365:template<int Y, int InfX, int SupX>
        -:  366:class meta_sqrt<Y, InfX, SupX, true> { public:  enum { ret = (SupX*SupX <= Y) ? SupX : InfX }; };
