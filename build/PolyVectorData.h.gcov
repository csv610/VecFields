        -:   30:    //bool perfectRoSy;               // Whether the field must be perfect rotationally-symmetric (but not unit).
        -:   31:    double wSmooth;                 // Weight of smoothness
        -:   32:    double wRoSy;                   // Weight of rotational-symmetry. "-1" means a perfect RoSy field (power field)
        -:   33:    Eigen::VectorXd wAlignment;     // Weight of alignment per each of the constfaces. "-1" means a fixed vector
        -:   34:    Eigen::VectorXd confidence;     // The confidence in each output of the iteration functions in the previous step (how much we want to keep it). Should be between [0,1], default is "1" (so it's transparent)
        -:   35:    double initImplicitFactor;      // Implicit smoothing factor
        -:   36:    double currImplicitFactor;      // The current implicit coeff in the given iteration
        -:   37:    double implicitScheduler;       // How much to attenuate the implicit factor with in each iteration
        -:   38:    int iterationMode;              // Making it possible to iterate energy reduction -> some custom projection function
        -:   39:    int currIteration;              // The current iteration
        -:   40:    bool implicitFirst;             // Whether to do the implicit step first or last
        -:   41: 
        -:   42:    Eigen::SparseMatrix<std::complex<double>> smoothMat;    //Smoothness energy
        -:   43:    Eigen::SparseMatrix<std::complex<double>> roSyMat;      //Rotational-symmetry energy
        -:   44:    Eigen::SparseMatrix<std::complex<double>> alignMat;     //(soft) alignment energy.
        -:   45:    Eigen::SparseMatrix<std::complex<double>> reducMat;     //reducing the fixed dofs (for instance with sign symmetry or fixed partial constraints)
        -:   46:    Eigen::VectorXcd reducRhs;                              //The uncompressed PV coeffs are reducMat*true_dofs+reducRhs
        -:   47:    Eigen::VectorXcd alignRhs;                              //encoding the soft constraints
        -:   48:    
        -:   49:    //Mass and stiffness matrices
        -:   50:    Eigen::SparseMatrix<std::complex<double>> WSmooth, WAlign, WRoSy, M;
        -:   51:    double totalRoSyWeight, totalConstrainedWeight, totalSmoothWeight, totalMass;    //for co-scaling energies
        -:   52:    
        -:   53:    //state-machine solvers and vectors
        -:   54:    Eigen::SparseMatrix<std::complex<double>> totalLhs;             //The total left-hand-side of the system
        -:   55:    Eigen::VectorXcd totalRhs;                                      //The total right-hand side
        -:   56:    Eigen::VectorXcd reducedDofs;                                   //The net solution in the minimal independent degrees of freedom
        -:   57:    Eigen::SparseMatrix<std::complex<double>> implicitLhs;          //The implicit system left-hand-side
        -:   58:    Eigen::VectorXcd implicitRhs;                                   //The implicit right-hand side
        -:   59:    Eigen::SparseMatrix<std::complex<double>> confidenceMat;        //The confidence matrix for implicit iterations
        -:   60:    Eigen::SimplicialLDLT<Eigen::SparseMatrix<std::complex<double>>> reducProjSolver;           //The solver for the reduced dofs from the full dofs (in Least squares)
        -:   61:    Eigen::SimplicialLDLT<Eigen::SparseMatrix<std::complex<double>>> implicitSolver;            //The solver for the implicit system
        -:   62:    
