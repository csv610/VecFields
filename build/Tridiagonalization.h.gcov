        -:  391:/** \brief Performs a full tridiagonalization in place
        -:  392:  *
        -:  393:  * \param[in,out]  mat  On input, the selfadjoint matrix whose tridiagonal
        -:  394:  *    decomposition is to be computed. Only the lower triangular part referenced.
        -:  395:  *    The rest is left unchanged. On output, the orthogonal matrix Q
        -:  396:  *    in the decomposition if \p extractQ is true.
        -:  397:  * \param[out]  diag  The diagonal of the tridiagonal matrix T in the
        -:  398:  *    decomposition.
        -:  399:  * \param[out]  subdiag  The subdiagonal of the tridiagonal matrix T in
        -:  400:  *    the decomposition.
        -:  401:  * \param[in]  extractQ  If true, the orthogonal matrix Q in the
        -:  402:  *    decomposition is computed and stored in \p mat.
        -:  403:  *
        -:  404:  * Computes the tridiagonal decomposition of the selfadjoint matrix \p mat in place
        -:  405:  * such that \f$ mat = Q T Q^* \f$ where \f$ Q \f$ is unitary and \f$ T \f$ a real
        -:  406:  * symmetric tridiagonal matrix.
        -:  407:  *
        -:  408:  * The tridiagonal matrix T is passed to the output parameters \p diag and \p subdiag. If
        -:  409:  * \p extractQ is true, then the orthogonal matrix Q is passed to \p mat. Otherwise the lower
        -:  410:  * part of the matrix \p mat is destroyed.
        -:  411:  *
        -:  412:  * The vectors \p diag and \p subdiag are not resized. The function
        -:  413:  * assumes that they are already of the correct size. The length of the
        -:  414:  * vector \p diag should equal the number of rows in \p mat, and the
        -:  415:  * length of the vector \p subdiag should be one left.
        -:  416:  *
        -:  417:  * This implementation contains an optimized path for 3-by-3 matrices
        -:  418:  * which is especially useful for plane fitting.
        -:  419:  *
        -:  420:  * \note Currently, it requires two temporary vectors to hold the intermediate
        -:  421:  * Householder coefficients, and to reconstruct the matrix Q from the Householder
        -:  422:  * reflectors.
        -:  423:  *
        -:  424:  * Example (this uses the same matrix as the example in
        -:  425:  *    Tridiagonalization::Tridiagonalization(const MatrixType&)):
        -:  426:  *    \include Tridiagonalization_decomposeInPlace.cpp
        -:  427:  * Output: \verbinclude Tridiagonalization_decomposeInPlace.out
        -:  428:  *
        -:  429:  * \sa class Tridiagonalization
        -:  430:  */
        -:  431:template<typename MatrixType, typename DiagonalType, typename SubDiagonalType, typename CoeffVectorType, typename WorkSpaceType>
        -:  432:EIGEN_DEVICE_FUNC
     1490:  433:void tridiagonalization_inplace(MatrixType& mat, DiagonalType& diag, SubDiagonalType& subdiag,
        -:  434:                                CoeffVectorType& hcoeffs, WorkSpaceType& workspace, bool extractQ)
        -:  435:{
     1490:  436:  eigen_assert(mat.cols()==mat.rows() && diag.size()==mat.rows() && subdiag.size()==mat.rows()-1);
     1490:  437:  tridiagonalization_inplace_selector<MatrixType>::run(mat, diag, subdiag, hcoeffs, workspace, extractQ);
     1490:  438:}
        -:  439:
        -:  440:/** \internal
        -:  441:  * General full tridiagonalization
        -:  442:  */
        -:  443:template<typename MatrixType, int Size, bool IsComplex>
        -:  444:struct tridiagonalization_inplace_selector
        -:  445:{
        -:  446:  typedef typename Tridiagonalization<MatrixType>::HouseholderSequenceType HouseholderSequenceType;
        -:  447:  template<typename DiagonalType, typename SubDiagonalType, typename CoeffVectorType, typename WorkSpaceType>
        -:  448:  static EIGEN_DEVICE_FUNC
     1490:  449:      void run(MatrixType& mat, DiagonalType& diag, SubDiagonalType& subdiag, CoeffVectorType& hCoeffs, WorkSpaceType& workspace, bool extractQ)
        -:  450:  {
     1490:  451:    tridiagonalization_inplace(mat, hCoeffs);
     1490:  452:    diag = mat.diagonal().real();
     1490:  453:    subdiag = mat.template diagonal<-1>().real();
     1490:  454:    if (extractQ) {
     1490:  455:      HouseholderSequenceType(mat, hCoeffs.conjugate())
     1490:  456:          .setLength(mat.rows() - 1)
     1490:  457:          .setShift(1)
     1490:  458:          .evalTo(mat, workspace);
     1490:  459:    }
     1490:  460:  }
        -:  461:};
        -:  462:
        -:  463:/** \internal
        -:  464:  * Specialization for 3x3 real matrices.
        -:  465:  * Especially useful for plane fitting.
        -:  466:  */
        -:  467:template<typename MatrixType>
        -:  468:struct tridiagonalization_inplace_selector<MatrixType,3,false>
        -:  469:{
        -:  470:  typedef typename MatrixType::Scalar Scalar;
        -:  471:  typedef typename MatrixType::RealScalar RealScalar;
        -:  472:
        -:  473:  template<typename DiagonalType, typename SubDiagonalType, typename CoeffVectorType, typename WorkSpaceType>
        -:  474:  static void run(MatrixType& mat, DiagonalType& diag, SubDiagonalType& subdiag, CoeffVectorType&, WorkSpaceType&, bool extractQ)
        -:  475:  {
        -:  476:    using std::sqrt;
        -:  477:    const RealScalar tol = (std::numeric_limits<RealScalar>::min)();
        -:  478:    diag[0] = mat(0,0);
        -:  479:    RealScalar v1norm2 = numext::abs2(mat(2,0));
        -:  480:    if(v1norm2 <= tol)
        -:  481:    {
        -:  482:      diag[1] = mat(1,1);
        -:  483:      diag[2] = mat(2,2);
        -:  484:      subdiag[0] = mat(1,0);
        -:  485:      subdiag[1] = mat(2,1);
        -:  486:      if (extractQ)
        -:  487:        mat.setIdentity();
        -:  488:    }
        -:  489:    else
        -:  490:    {
        -:  491:      RealScalar beta = sqrt(numext::abs2(mat(1,0)) + v1norm2);
        -:  492:      RealScalar invBeta = RealScalar(1)/beta;
        -:  493:      Scalar m01 = mat(1,0) * invBeta;
        -:  494:      Scalar m02 = mat(2,0) * invBeta;
        -:  495:      Scalar q = RealScalar(2)*m01*mat(2,1) + m02*(mat(2,2) - mat(1,1));
        -:  496:      diag[1] = mat(1,1) + m02*q;
        -:  497:      diag[2] = mat(2,2) - m02*q;
        -:  498:      subdiag[0] = beta;
        -:  499:      subdiag[1] = mat(2,1) - m01 * q;
        -:  500:      if (extractQ)
        -:  501:      {
        -:  502:        mat << 1,   0,    0,
        -:  503:               0, m01,  m02,
        -:  504:               0, m02, -m01;
        -:  505:      }
        -:  506:    }
        -:  507:  }
        -:  508:};
        -:  509:
        -:  510:/** \internal
        -:  511:  * Trivial specialization for 1x1 matrices
        -:  512:  */
        -:  513:template<typename MatrixType, bool IsComplex>
        -:  514:struct tridiagonalization_inplace_selector<MatrixType,1,IsComplex>
        -:  515:{
        -:  516:  typedef typename MatrixType::Scalar Scalar;
        -:  517:
        -:  518:  template<typename DiagonalType, typename SubDiagonalType, typename CoeffVectorType, typename WorkSpaceType>
        -:  519:  static EIGEN_DEVICE_FUNC
        -:  520:  void run(MatrixType& mat, DiagonalType& diag, SubDiagonalType&, CoeffVectorType&, WorkSpaceType&, bool extractQ)
        -:  521:  {
        -:  522:    diag(0,0) = numext::real(mat(0,0));
        -:  523:    if(extractQ)
        -:  524:      mat(0,0) = Scalar(1);
        -:  525:  }
        -:  526:};
