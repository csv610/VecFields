        -:  306:    EIGEN_DEVICE_FUNC
    10430:  307:    const RealVectorType& eigenvalues() const
        -:  308:    {
    20860:  309:      eigen_assert(m_isInitialized && "SelfAdjointEigenSolver is not initialized.");
    10430:  310:      return m_eivalues;
        -:  311:    }
        -:  312:
        -:  313:    /** \brief Computes the positive-definite square root of the matrix.
        -:  314:      *
        -:  315:      * \returns the positive-definite square root of the matrix
        -:  316:      *
        -:  317:      * \pre The eigenvalues and eigenvectors of a positive-definite matrix
        -:  318:      * have been computed before.
        -:  319:      *
        -:  320:      * The square root of a positive-definite matrix \f$ A \f$ is the
        -:  321:      * positive-definite matrix whose square equals \f$ A \f$. This function
        -:  322:      * uses the eigendecomposition \f$ A = V D V^{-1} \f$ to compute the
        -:  323:      * square root as \f$ A^{1/2} = V D^{1/2} V^{-1} \f$.
        -:  324:      *
        -:  325:      * Example: \include SelfAdjointEigenSolver_operatorSqrt.cpp
        -:  326:      * Output: \verbinclude SelfAdjointEigenSolver_operatorSqrt.out
        -:  327:      *
        -:  328:      * \sa operatorInverseSqrt(), <a href="unsupported/group__MatrixFunctions__Module.html">MatrixFunctions Module</a>
        -:  329:      */
        -:  330:    EIGEN_DEVICE_FUNC
        -:  331:    MatrixType operatorSqrt() const
        -:  332:    {
        -:  333:      eigen_assert(m_isInitialized && "SelfAdjointEigenSolver is not initialized.");
        -:  334:      eigen_assert(m_eigenvectorsOk && "The eigenvectors have not been computed together with the eigenvalues.");
        -:  335:      return m_eivec * m_eivalues.cwiseSqrt().asDiagonal() * m_eivec.adjoint();
        -:  336:    }
        -:  337:
        -:  338:    /** \brief Computes the inverse square root of the matrix.
        -:  339:      *
        -:  340:      * \returns the inverse positive-definite square root of the matrix
        -:  341:      *
        -:  342:      * \pre The eigenvalues and eigenvectors of a positive-definite matrix
        -:  343:      * have been computed before.
        -:  344:      *
        -:  345:      * This function uses the eigendecomposition \f$ A = V D V^{-1} \f$ to
        -:  346:      * compute the inverse square root as \f$ V D^{-1/2} V^{-1} \f$. This is
        -:  347:      * cheaper than first computing the square root with operatorSqrt() and
        -:  348:      * then its inverse with MatrixBase::inverse().
        -:  349:      *
        -:  350:      * Example: \include SelfAdjointEigenSolver_operatorInverseSqrt.cpp
        -:  351:      * Output: \verbinclude SelfAdjointEigenSolver_operatorInverseSqrt.out
        -:  352:      *
        -:  353:      * \sa operatorSqrt(), MatrixBase::inverse(), <a href="unsupported/group__MatrixFunctions__Module.html">MatrixFunctions Module</a>
        -:  354:      */
        -:  355:    EIGEN_DEVICE_FUNC
        -:  356:    MatrixType operatorInverseSqrt() const
        -:  357:    {
        -:  358:      eigen_assert(m_isInitialized && "SelfAdjointEigenSolver is not initialized.");
        -:  359:      eigen_assert(m_eigenvectorsOk && "The eigenvectors have not been computed together with the eigenvalues.");
        -:  360:      return m_eivec * m_eivalues.cwiseInverse().cwiseSqrt().asDiagonal() * m_eivec.adjoint();
        -:  361:    }
        -:  362:
        -:  363:    /** \brief Reports whether previous computation was successful.
        -:  364:      *
        -:  365:      * \returns \c Success if computation was successful, \c NoConvergence otherwise.
        -:  366:      */
        -:  367:    EIGEN_DEVICE_FUNC
        -:  368:    ComputationInfo info() const
        -:  369:    {
        -:  370:      eigen_assert(m_isInitialized && "SelfAdjointEigenSolver is not initialized.");
        -:  371:      return m_info;
        -:  372:    }
        -:  373:
        -:  374:    /** \brief Maximum number of iterations.
        -:  375:      *
        -:  376:      * The algorithm terminates if it does not converge within m_maxIterations * n iterations, where n
        -:  377:      * denotes the size of the matrix. This value is currently set to 30 (copied from LAPACK).
        -:  378:      */
        -:  379:    static const int m_maxIterations = 30;
