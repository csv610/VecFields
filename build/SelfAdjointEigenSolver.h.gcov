        -:   32:/** \eigenvalues_module \ingroup Eigenvalues_Module
        -:   33:  *
        -:   34:  *
        -:   35:  * \class SelfAdjointEigenSolver
        -:   36:  *
        -:   37:  * \brief Computes eigenvalues and eigenvectors of selfadjoint matrices
        -:   38:  *
        -:   39:  * \tparam MatrixType_ the type of the matrix of which we are computing the
        -:   40:  * eigendecomposition; this is expected to be an instantiation of the Matrix
        -:   41:  * class template.
        -:   42:  *
        -:   43:  * A matrix \f$ A \f$ is selfadjoint if it equals its adjoint. For real
        -:   44:  * matrices, this means that the matrix is symmetric: it equals its
        -:   45:  * transpose. This class computes the eigenvalues and eigenvectors of a
        -:   46:  * selfadjoint matrix. These are the scalars \f$ \lambda \f$ and vectors
        -:   47:  * \f$ v \f$ such that \f$ Av = \lambda v \f$.  The eigenvalues of a
        -:   48:  * selfadjoint matrix are always real. If \f$ D \f$ is a diagonal matrix with
        -:   49:  * the eigenvalues on the diagonal, and \f$ V \f$ is a matrix with the
        -:   50:  * eigenvectors as its columns, then \f$ A = V D V^{-1} \f$. This is called the
        -:   51:  * eigendecomposition.
        -:   52:  *
        -:   53:  * For a selfadjoint matrix, \f$ V \f$ is unitary, meaning its inverse is equal
        -:   54:  * to its adjoint, \f$ V^{-1} = V^{\dagger} \f$. If \f$ A \f$ is real, then
        -:   55:  * \f$ V \f$ is also real and therefore orthogonal, meaning its inverse is
        -:   56:  * equal to its transpose, \f$ V^{-1} = V^T \f$.
        -:   57:  *
        -:   58:  * The algorithm exploits the fact that the matrix is selfadjoint, making it
        -:   59:  * faster and more accurate than the general purpose eigenvalue algorithms
        -:   60:  * implemented in EigenSolver and ComplexEigenSolver.
        -:   61:  *
        -:   62:  * Only the \b lower \b triangular \b part of the input matrix is referenced.
        -:   63:  *
        -:   64:  * Call the function compute() to compute the eigenvalues and eigenvectors of
        -:   65:  * a given matrix. Alternatively, you can use the
        -:   66:  * SelfAdjointEigenSolver(const MatrixType&, int) constructor which computes
        -:   67:  * the eigenvalues and eigenvectors at construction time. Once the eigenvalue
        -:   68:  * and eigenvectors are computed, they can be retrieved with the eigenvalues()
        -:   69:  * and eigenvectors() functions.
        -:   70:  *
        -:   71:  * The documentation for SelfAdjointEigenSolver(const MatrixType&, int)
        -:   72:  * contains an example of the typical use of this class.
        -:   73:  *
        -:   74:  * To solve the \em generalized eigenvalue problem \f$ Av = \lambda Bv \f$ and
        -:   75:  * the likes, see the class GeneralizedSelfAdjointEigenSolver.
        -:   76:  *
        -:   77:  * \sa MatrixBase::eigenvalues(), class EigenSolver, class ComplexEigenSolver
        -:   78:  */
        -:   79:template<typename MatrixType_> class SelfAdjointEigenSolver
        -:   80:{
        -:   81:  public:
        -:   82:
        -:   83:    typedef MatrixType_ MatrixType;
        -:   84:    enum {
        -:   85:      Size = MatrixType::RowsAtCompileTime,
        -:   86:      ColsAtCompileTime = MatrixType::ColsAtCompileTime,
        -:   87:      Options = MatrixType::Options,
        -:   88:      MaxColsAtCompileTime = MatrixType::MaxColsAtCompileTime
        -:   89:    };
        -:   90:    
        -:   91:    /** \brief Scalar type for matrices of type \p MatrixType_. */
        -:   92:    typedef typename MatrixType::Scalar Scalar;
        -:   93:    typedef Eigen::Index Index; ///< \deprecated since Eigen 3.3
        -:   94:    
        -:   95:    typedef Matrix<Scalar,Size,Size,ColMajor,MaxColsAtCompileTime,MaxColsAtCompileTime> EigenvectorsType;
        -:   96:
        -:   97:    /** \brief Real scalar type for \p MatrixType_.
        -:   98:      *
        -:   99:      * This is just \c Scalar if #Scalar is real (e.g., \c float or
        -:  100:      * \c double), and the type of the real part of \c Scalar if #Scalar is
        -:  101:      * complex.
        -:  102:      */
        -:  103:    typedef typename NumTraits<Scalar>::Real RealScalar;
        -:  104:    
        -:  105:    friend struct internal::direct_selfadjoint_eigenvalues<SelfAdjointEigenSolver,Size,NumTraits<Scalar>::IsComplex>;
        -:  106:
        -:  107:    /** \brief Type for vector of eigenvalues as returned by eigenvalues().
        -:  108:      *
        -:  109:      * This is a column vector with entries of type #RealScalar.
        -:  110:      * The length of the vector is the size of \p MatrixType_.
        -:  111:      */
        -:  112:    typedef typename internal::plain_col_type<MatrixType, Scalar>::type VectorType;
        -:  113:    typedef typename internal::plain_col_type<MatrixType, RealScalar>::type RealVectorType;
        -:  114:    typedef Tridiagonalization<MatrixType> TridiagonalizationType;
        -:  115:    typedef typename TridiagonalizationType::SubDiagonalType SubDiagonalType;
        -:  116:
        -:  117:    /** \brief Default constructor for fixed-size matrices.
        -:  118:      *
        -:  119:      * The default constructor is useful in cases in which the user intends to
        -:  120:      * perform decompositions via compute(). This constructor
        -:  121:      * can only be used if \p MatrixType_ is a fixed-size matrix; use
        -:  122:      * SelfAdjointEigenSolver(Index) for dynamic-size matrices.
        -:  123:      *
        -:  124:      * Example: \include SelfAdjointEigenSolver_SelfAdjointEigenSolver.cpp
        -:  125:      * Output: \verbinclude SelfAdjointEigenSolver_SelfAdjointEigenSolver.out
        -:  126:      */
        -:  127:    EIGEN_DEVICE_FUNC
        -:  128:    SelfAdjointEigenSolver()
        -:  129:        : m_eivec(),
        -:  130:          m_workspace(),
        -:  131:          m_eivalues(),
        -:  132:          m_subdiag(),
        -:  133:          m_hcoeffs(),
        -:  134:          m_info(InvalidInput),
        -:  135:          m_isInitialized(false),
        -:  136:          m_eigenvectorsOk(false)
        -:  137:    { }
        -:  138:
        -:  139:    /** \brief Constructor, pre-allocates memory for dynamic-size matrices.
        -:  140:      *
        -:  141:      * \param [in]  size  Positive integer, size of the matrix whose
        -:  142:      * eigenvalues and eigenvectors will be computed.
        -:  143:      *
        -:  144:      * This constructor is useful for dynamic-size matrices, when the user
        -:  145:      * intends to perform decompositions via compute(). The \p size
        -:  146:      * parameter is only used as a hint. It is not an error to give a wrong
        -:  147:      * \p size, but it may impair performance.
        -:  148:      *
        -:  149:      * \sa compute() for an example
        -:  150:      */
        -:  151:    EIGEN_DEVICE_FUNC
        -:  152:    explicit SelfAdjointEigenSolver(Index size)
        -:  153:        : m_eivec(size, size),
        -:  154:          m_workspace(size),
        -:  155:          m_eivalues(size),
        -:  156:          m_subdiag(size > 1 ? size - 1 : 1),
        -:  157:          m_hcoeffs(size > 1 ? size - 1 : 1),
        -:  158:          m_isInitialized(false),
        -:  159:          m_eigenvectorsOk(false)
