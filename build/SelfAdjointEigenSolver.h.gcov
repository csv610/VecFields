        -:  162:    /** \brief Constructor; computes eigendecomposition of given matrix.
        -:  163:      *
        -:  164:      * \param[in]  matrix  Selfadjoint matrix whose eigendecomposition is to
        -:  165:      *    be computed. Only the lower triangular part of the matrix is referenced.
        -:  166:      * \param[in]  options Can be #ComputeEigenvectors (default) or #EigenvaluesOnly.
        -:  167:      *
        -:  168:      * This constructor calls compute(const MatrixType&, int) to compute the
        -:  169:      * eigenvalues of the matrix \p matrix. The eigenvectors are computed if
        -:  170:      * \p options equals #ComputeEigenvectors.
        -:  171:      *
        -:  172:      * Example: \include SelfAdjointEigenSolver_SelfAdjointEigenSolver_MatrixType.cpp
        -:  173:      * Output: \verbinclude SelfAdjointEigenSolver_SelfAdjointEigenSolver_MatrixType.out
        -:  174:      *
        -:  175:      * \sa compute(const MatrixType&, int)
        -:  176:      */
        -:  177:    template<typename InputType>
        -:  178:    EIGEN_DEVICE_FUNC
     2980:  179:    explicit SelfAdjointEigenSolver(const EigenBase<InputType>& matrix, int options = ComputeEigenvectors)
     1490:  180:      : m_eivec(matrix.rows(), matrix.cols()),
     1490:  181:        m_workspace(matrix.cols()),
     1490:  182:        m_eivalues(matrix.cols()),
     1490:  183:        m_subdiag(matrix.rows() > 1 ? matrix.rows() - 1 : 1),
     1490:  184:        m_hcoeffs(matrix.cols() > 1 ? matrix.cols() - 1 : 1),
     1490:  185:        m_isInitialized(false),
     1490:  186:        m_eigenvectorsOk(false)
     1490:  187:    {
     1490:  188:      compute(matrix.derived(), options);
     2980:  189:    }
        -:  190:
        -:  191:    /** \brief Computes eigendecomposition of given matrix.
        -:  192:      *
        -:  193:      * \param[in]  matrix  Selfadjoint matrix whose eigendecomposition is to
        -:  194:      *    be computed. Only the lower triangular part of the matrix is referenced.
        -:  195:      * \param[in]  options Can be #ComputeEigenvectors (default) or #EigenvaluesOnly.
        -:  196:      * \returns    Reference to \c *this
        -:  197:      *
        -:  198:      * This function computes the eigenvalues of \p matrix.  The eigenvalues()
        -:  199:      * function can be used to retrieve them.  If \p options equals #ComputeEigenvectors,
        -:  200:      * then the eigenvectors are also computed and can be retrieved by
        -:  201:      * calling eigenvectors().
        -:  202:      *
        -:  203:      * This implementation uses a symmetric QR algorithm. The matrix is first
        -:  204:      * reduced to tridiagonal form using the Tridiagonalization class. The
        -:  205:      * tridiagonal matrix is then brought to diagonal form with implicit
        -:  206:      * symmetric QR steps with Wilkinson shift. Details can be found in
        -:  207:      * Section 8.3 of Golub \& Van Loan, <i>%Matrix Computations</i>.
        -:  208:      *
        -:  209:      * The cost of the computation is about \f$ 9n^3 \f$ if the eigenvectors
        -:  210:      * are required and \f$ 4n^3/3 \f$ if they are not required.
        -:  211:      *
        -:  212:      * This method reuses the memory in the SelfAdjointEigenSolver object that
        -:  213:      * was allocated when the object was constructed, if the size of the
        -:  214:      * matrix does not change.
        -:  215:      *
        -:  216:      * Example: \include SelfAdjointEigenSolver_compute_MatrixType.cpp
        -:  217:      * Output: \verbinclude SelfAdjointEigenSolver_compute_MatrixType.out
        -:  218:      *
        -:  219:      * \sa SelfAdjointEigenSolver(const MatrixType&, int)
        -:  220:      */
        -:  221:    template<typename InputType>
        -:  222:    EIGEN_DEVICE_FUNC
        -:  223:    SelfAdjointEigenSolver& compute(const EigenBase<InputType>& matrix, int options = ComputeEigenvectors);
        -:  224:    
        -:  225:    /** \brief Computes eigendecomposition of given matrix using a closed-form algorithm
        -:  226:      *
        -:  227:      * This is a variant of compute(const MatrixType&, int options) which
        -:  228:      * directly solves the underlying polynomial equation.
        -:  229:      * 
        -:  230:      * Currently only 2x2 and 3x3 matrices for which the sizes are known at compile time are supported (e.g., Matrix3d).
        -:  231:      * 
        -:  232:      * This method is usually significantly faster than the QR iterative algorithm
        -:  233:      * but it might also be less accurate. It is also worth noting that
        -:  234:      * for 3x3 matrices it involves trigonometric operations which are
        -:  235:      * not necessarily available for all scalar types.
        -:  236:      * 
        -:  237:      * For the 3x3 case, we observed the following worst case relative error regarding the eigenvalues:
        -:  238:      *   - double: 1e-8
        -:  239:      *   - float:  1e-3
        -:  240:      *
        -:  241:      * \sa compute(const MatrixType&, int options)
        -:  242:      */
        -:  243:    EIGEN_DEVICE_FUNC
        -:  244:    SelfAdjointEigenSolver& computeDirect(const MatrixType& matrix, int options = ComputeEigenvectors);
        -:  245:
        -:  246:    /**
        -:  247:      *\brief Computes the eigen decomposition from a tridiagonal symmetric matrix
        -:  248:      *
        -:  249:      * \param[in] diag The vector containing the diagonal of the matrix.
        -:  250:      * \param[in] subdiag The subdiagonal of the matrix.
        -:  251:      * \param[in] options Can be #ComputeEigenvectors (default) or #EigenvaluesOnly.
        -:  252:      * \returns Reference to \c *this
        -:  253:      *
        -:  254:      * This function assumes that the matrix has been reduced to tridiagonal form.
        -:  255:      *
        -:  256:      * \sa compute(const MatrixType&, int) for more information
        -:  257:      */
        -:  258:    SelfAdjointEigenSolver& computeFromTridiagonal(const RealVectorType& diag, const SubDiagonalType& subdiag , int options=ComputeEigenvectors);
        -:  259:
        -:  260:    /** \brief Returns the eigenvectors of given matrix.
        -:  261:      *
        -:  262:      * \returns  A const reference to the matrix whose columns are the eigenvectors.
        -:  263:      *
        -:  264:      * \pre The eigenvectors have been computed before.
        -:  265:      *
        -:  266:      * Column \f$ k \f$ of the returned matrix is an eigenvector corresponding
        -:  267:      * to eigenvalue number \f$ k \f$ as returned by eigenvalues().  The
        -:  268:      * eigenvectors are normalized to have (Euclidean) norm equal to one. If
        -:  269:      * this object was used to solve the eigenproblem for the selfadjoint
        -:  270:      * matrix \f$ A \f$, then the matrix returned by this function is the
        -:  271:      * matrix \f$ V \f$ in the eigendecomposition \f$ A = V D V^{-1} \f$.
        -:  272:      *
        -:  273:      * For a selfadjoint matrix, \f$ V \f$ is unitary, meaning its inverse is equal
        -:  274:      * to its adjoint, \f$ V^{-1} = V^{\dagger} \f$. If \f$ A \f$ is real, then
        -:  275:      * \f$ V \f$ is also real and therefore orthogonal, meaning its inverse is
        -:  276:      * equal to its transpose, \f$ V^{-1} = V^T \f$.
        -:  277:      *
        -:  278:      * Example: \include SelfAdjointEigenSolver_eigenvectors.cpp
        -:  279:      * Output: \verbinclude SelfAdjointEigenSolver_eigenvectors.out
        -:  280:      *
        -:  281:      * \sa eigenvalues()
        -:  282:      */
        -:  283:    EIGEN_DEVICE_FUNC
     2980:  284:    const EigenvectorsType& eigenvectors() const
        -:  285:    {
     5960:  286:      eigen_assert(m_isInitialized && "SelfAdjointEigenSolver is not initialized.");
     5960:  287:      eigen_assert(m_eigenvectorsOk && "The eigenvectors have not been computed together with the eigenvalues.");
     2980:  288:      return m_eivec;
        -:  289:    }
        -:  290:
        -:  291:    /** \brief Returns the eigenvalues of given matrix.
        -:  292:      *
        -:  293:      * \returns A const reference to the column vector containing the eigenvalues.
        -:  294:      *
        -:  295:      * \pre The eigenvalues have been computed before.
        -:  296:      *
        -:  297:      * The eigenvalues are repeated according to their algebraic multiplicity,
        -:  298:      * so there are as many eigenvalues as rows in the matrix. The eigenvalues
        -:  299:      * are sorted in increasing order.
        -:  300:      *
        -:  301:      * Example: \include SelfAdjointEigenSolver_eigenvalues.cpp
        -:  302:      * Output: \verbinclude SelfAdjointEigenSolver_eigenvalues.out
        -:  303:      *
