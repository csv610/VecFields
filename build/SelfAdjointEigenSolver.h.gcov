        -:  393:
        -:  394:namespace internal {
        -:  395:/** \internal
        -:  396:  *
        -:  397:  * \eigenvalues_module \ingroup Eigenvalues_Module
        -:  398:  *
        -:  399:  * Performs a QR step on a tridiagonal symmetric matrix represented as a
        -:  400:  * pair of two vectors \a diag and \a subdiag.
        -:  401:  *
        -:  402:  * \param diag the diagonal part of the input selfadjoint tridiagonal matrix
        -:  403:  * \param subdiag the sub-diagonal part of the input selfadjoint tridiagonal matrix
        -:  404:  * \param start starting index of the submatrix to work on
        -:  405:  * \param end last+1 index of the submatrix to work on
        -:  406:  * \param matrixQ pointer to the column-major matrix holding the eigenvectors, can be 0
        -:  407:  * \param n size of the input matrix
        -:  408:  *
        -:  409:  * For compilation efficiency reasons, this procedure does not use eigen expression
        -:  410:  * for its arguments.
        -:  411:  *
        -:  412:  * Implemented from Golub's "Matrix Computations", algorithm 8.3.2:
        -:  413:  * "implicit symmetric QR step with Wilkinson shift"
        -:  414:  */
