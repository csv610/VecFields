        -:  502:
        -:  503://------------------------------------------------------------------------------------------
        -:  504:// Detect GPU compilers and architectures
        -:  505://------------------------------------------------------------------------------------------
        -:  506:
        -:  507:// NVCC is not supported as the target platform for HIPCC
        -:  508:// Note that this also makes EIGEN_CUDACC and EIGEN_HIPCC mutually exclusive
        -:  509:#if defined(__NVCC__) && defined(__HIPCC__)
        -:  510:  #error "NVCC as the target platform for HIPCC is currently not supported."
        -:  511:#endif
        -:  512:
        -:  513:#if defined(__CUDACC__) && !defined(EIGEN_NO_CUDA) && !defined(__SYCL_DEVICE_ONLY__)
        -:  514:  // Means the compiler is either nvcc or clang with CUDA enabled
        -:  515:  #define EIGEN_CUDACC __CUDACC__
        -:  516:#endif
        -:  517:
        -:  518:#if defined(__CUDA_ARCH__) && !defined(EIGEN_NO_CUDA) && !defined(__SYCL_DEVICE_ONLY__)
        -:  519:  // Means we are generating code for the device
        -:  520:  #define EIGEN_CUDA_ARCH __CUDA_ARCH__
        -:  521:#endif
        -:  522:
        -:  523:#if defined(EIGEN_CUDACC)
        -:  524:#include <cuda.h>
        -:  525:  #define EIGEN_CUDA_SDK_VER (CUDA_VERSION * 10)
        -:  526:#else
        -:  527:  #define EIGEN_CUDA_SDK_VER 0
        -:  528:#endif
        -:  529:
        -:  530:#if defined(__HIPCC__) && !defined(EIGEN_NO_HIP) && !defined(__SYCL_DEVICE_ONLY__)
        -:  531:  // Means the compiler is HIPCC (analogous to EIGEN_CUDACC, but for HIP)
        -:  532:  #define EIGEN_HIPCC __HIPCC__
        -:  533:
        -:  534:  // We need to include hip_runtime.h here because it pulls in
        -:  535:  // ++ hip_common.h which contains the define for  __HIP_DEVICE_COMPILE__
        -:  536:  // ++ host_defines.h which contains the defines for the __host__ and __device__ macros
        -:  537:  #include <hip/hip_runtime.h>
        -:  538:
        -:  539:  #if defined(__HIP_DEVICE_COMPILE__) && !defined(__SYCL_DEVICE_ONLY__)
        -:  540:    // analogous to EIGEN_CUDA_ARCH, but for HIP
        -:  541:    #define EIGEN_HIP_DEVICE_COMPILE __HIP_DEVICE_COMPILE__
        -:  542:  #endif
        -:  543:
        -:  544:  // For HIP (ROCm 3.5 and higher), we need to explicitly set the launch_bounds attribute
        -:  545:  // value to 1024. The compiler assigns a default value of 256 when the attribute is not
        -:  546:  // specified. This results in failures on the HIP platform, for cases when a GPU kernel
        -:  547:  // without an explicit launch_bounds attribute is called with a threads_per_block value
        -:  548:  // greater than 256.
        -:  549:  //
        -:  550:  // This is a regression in functioanlity and is expected to be fixed within the next
        -:  551:  // couple of ROCm releases (compiler will go back to using 1024 value as the default)
        -:  552:  //
        -:  553:  // In the meantime, we will use a "only enabled for HIP" macro to set the launch_bounds
        -:  554:  // attribute.
        -:  555:
        -:  556:  #define EIGEN_HIP_LAUNCH_BOUNDS_1024 __launch_bounds__(1024)
        -:  557:
        -:  558:#endif
        -:  559:
        -:  560:#if !defined(EIGEN_HIP_LAUNCH_BOUNDS_1024)
        -:  561:#define EIGEN_HIP_LAUNCH_BOUNDS_1024
        -:  562:#endif // !defined(EIGEN_HIP_LAUNCH_BOUNDS_1024)
        -:  563:
        -:  564:// Unify CUDA/HIPCC
        -:  565:
        -:  566:#if defined(EIGEN_CUDACC) || defined(EIGEN_HIPCC)
        -:  567://
        -:  568:// If either EIGEN_CUDACC or EIGEN_HIPCC is defined, then define EIGEN_GPUCC
        -:  569://
        -:  570:#define EIGEN_GPUCC
        -:  571://
        -:  572:// EIGEN_HIPCC implies the HIP compiler and is used to tweak Eigen code for use in HIP kernels
        -:  573:// EIGEN_CUDACC implies the CUDA compiler and is used to tweak Eigen code for use in CUDA kernels
        -:  574://
        -:  575:// In most cases the same tweaks are required to the Eigen code to enable in both the HIP and CUDA kernels.
        -:  576:// For those cases, the corresponding code should be guarded with
        -:  577://      #if defined(EIGEN_GPUCC)
        -:  578:// instead of
        -:  579://      #if defined(EIGEN_CUDACC) || defined(EIGEN_HIPCC)
        -:  580://
        -:  581:// For cases where the tweak is specific to HIP, the code should be guarded with
        -:  582://      #if defined(EIGEN_HIPCC)
        -:  583://
        -:  584:// For cases where the tweak is specific to CUDA, the code should be guarded with
        -:  585://      #if defined(EIGEN_CUDACC)
        -:  586://
        -:  587:#endif
        -:  588:
        -:  589:#if defined(EIGEN_CUDA_ARCH) || defined(EIGEN_HIP_DEVICE_COMPILE)
        -:  590://
        -:  591:// If either EIGEN_CUDA_ARCH or EIGEN_HIP_DEVICE_COMPILE is defined, then define EIGEN_GPU_COMPILE_PHASE
        -:  592://
        -:  593:#define EIGEN_GPU_COMPILE_PHASE
        -:  594://
        -:  595:// GPU compilers (HIPCC, NVCC) typically do two passes over the source code,
        -:  596://   + one to compile the source for the "host" (ie CPU)
        -:  597://   + another to compile the source for the "device" (ie. GPU)
        -:  598://
        -:  599:// Code that needs to enabled only during the either the "host" or "device" compilation phase
        -:  600:// needs to be guarded with a macro that indicates the current compilation phase
        -:  601://
        -:  602:// EIGEN_HIP_DEVICE_COMPILE implies the device compilation phase in HIP
        -:  603:// EIGEN_CUDA_ARCH implies the device compilation phase in CUDA
        -:  604://
        -:  605:// In most cases, the "host" / "device" specific code is the same for both HIP and CUDA
        -:  606:// For those cases, the code should be guarded with
        -:  607://       #if defined(EIGEN_GPU_COMPILE_PHASE)
        -:  608:// instead of
        -:  609://       #if defined(EIGEN_CUDA_ARCH) || defined(EIGEN_HIP_DEVICE_COMPILE)
        -:  610://
        -:  611:// For cases where the tweak is specific to HIP, the code should be guarded with
        -:  612://      #if defined(EIGEN_HIP_DEVICE_COMPILE)
        -:  613://
        -:  614:// For cases where the tweak is specific to CUDA, the code should be guarded with
        -:  615://      #if defined(EIGEN_CUDA_ARCH)
        -:  616://
        -:  617:#endif
        -:  618:
        -:  619:/// \internal EIGEN_HAS_ARM64_FP16_VECTOR_ARITHMETIC set to 1 if the architecture
        -:  620:/// supports Neon vector intrinsics for fp16.
        -:  621:#if EIGEN_ARCH_ARM_OR_ARM64
        -:  622:  #ifndef EIGEN_HAS_ARM64_FP16_VECTOR_ARITHMETIC
        -:  623:    // Clang only supports FP16 on aarch64, and not all intrinsics are available
        -:  624:    // on A32 anyways even in GCC (e.g. vdiv_f16, vsqrt_f16).
        -:  625:    #if EIGEN_ARCH_ARM64 && defined(__ARM_FEATURE_FP16_VECTOR_ARITHMETIC) && !defined(EIGEN_GPU_COMPILE_PHASE)
        -:  626:      #define EIGEN_HAS_ARM64_FP16_VECTOR_ARITHMETIC 1
        -:  627:    #else
        -:  628:      #define EIGEN_HAS_ARM64_FP16_VECTOR_ARITHMETIC 0
        -:  629:    #endif
        -:  630:  #endif
        -:  631:#endif
        -:  632:
        -:  633:/// \internal EIGEN_HAS_ARM64_FP16_SCALAR_ARITHMETIC set to 1 if the architecture
        -:  634:/// supports Neon scalar intrinsics for fp16.
        -:  635:#if EIGEN_ARCH_ARM_OR_ARM64
        -:  636:  #ifndef EIGEN_HAS_ARM64_FP16_SCALAR_ARITHMETIC
        -:  637:    // Clang only supports FP16 on aarch64, and not all intrinsics are available
        -:  638:    // on A32 anyways, even in GCC (e.g. vceqh_f16).
        -:  639:    #if EIGEN_ARCH_ARM64 && defined(__ARM_FEATURE_FP16_SCALAR_ARITHMETIC) && !defined(EIGEN_GPU_COMPILE_PHASE)
        -:  640:      #define EIGEN_HAS_ARM64_FP16_SCALAR_ARITHMETIC 1
        -:  641:    #endif
        -:  642:  #endif
        -:  643:#endif
        -:  644:
        -:  645:#if defined(EIGEN_USE_SYCL) && defined(__SYCL_DEVICE_ONLY__)
        -:  646:// EIGEN_USE_SYCL is a user-defined macro while __SYCL_DEVICE_ONLY__ is a compiler-defined macro.
        -:  647:// In most cases we want to check if both macros are defined which can be done using the define below.
        -:  648:#define SYCL_DEVICE_ONLY
        -:  649:#endif
        -:  650:
        -:  651://------------------------------------------------------------------------------------------
        -:  652:// Detect Compiler/Architecture/OS specific features
        -:  653://------------------------------------------------------------------------------------------
        -:  654:
        -:  655:// Cross compiler wrapper around LLVM's __has_builtin
        -:  656:#ifdef __has_builtin
        -:  657:#  define EIGEN_HAS_BUILTIN(x) __has_builtin(x)
        -:  658:#else
        -:  659:#  define EIGEN_HAS_BUILTIN(x) 0
        -:  660:#endif
        -:  661:
        -:  662:// A Clang feature extension to determine compiler features.
        -:  663:// We use it to determine 'cxx_rvalue_references'
        -:  664:#ifndef __has_feature
        -:  665:# define __has_feature(x) 0
        -:  666:#endif
        -:  667:
        -:  668:// The macro EIGEN_CPLUSPLUS is a replacement for __cplusplus/_MSVC_LANG that
        -:  669:// works for both platforms, indicating the C++ standard version number.
        -:  670://
        -:  671:// With MSVC, without defining /Zc:__cplusplus, the __cplusplus macro will
        -:  672:// report 199711L regardless of the language standard specified via /std.
        -:  673:// We need to rely on _MSVC_LANG instead, which is only available after
        -:  674:// VS2015.3.
        -:  675:#if EIGEN_COMP_MSVC_LANG > 0
        -:  676:#define EIGEN_CPLUSPLUS EIGEN_COMP_MSVC_LANG
        -:  677:#elif EIGEN_COMP_MSVC >= 1900
        -:  678:#define EIGEN_CPLUSPLUS 201103L
        -:  679:#elif defined(__cplusplus)
        -:  680:#define EIGEN_CPLUSPLUS __cplusplus
        -:  681:#else
        -:  682:#define EIGEN_CPLUSPLUS 0
        -:  683:#endif
        -:  684:
        -:  685:// The macro EIGEN_COMP_CXXVER defines the c++ version expected by the compiler.
        -:  686:// For instance, if compiling with gcc and -std=c++17, then EIGEN_COMP_CXXVER
        -:  687:// is defined to 17.
        -:  688:#if EIGEN_CPLUSPLUS >= 202002L
        -:  689:  #define EIGEN_COMP_CXXVER 20
        -:  690:#elif EIGEN_CPLUSPLUS >= 201703L
        -:  691:  #define EIGEN_COMP_CXXVER 17
        -:  692:#elif EIGEN_CPLUSPLUS >= 201402L
        -:  693:  #define EIGEN_COMP_CXXVER 14
        -:  694:#elif EIGEN_CPLUSPLUS >= 201103L
        -:  695:  #define EIGEN_COMP_CXXVER 11
        -:  696:#else
        -:  697:  #define EIGEN_COMP_CXXVER 03
        -:  698:#endif
        -:  699:
        -:  700:
        -:  701:// The macros EIGEN_HAS_CXX?? defines a rough estimate of available c++ features
        -:  702:// but in practice we should not rely on them but rather on the availability of
        -:  703:// individual features as defined later.
        -:  704:// This is why there is no EIGEN_HAS_CXX17.
        -:  705:#if EIGEN_MAX_CPP_VER < 14 || EIGEN_COMP_CXXVER < 14 || \
        -:  706:  (EIGEN_COMP_MSVC && EIGEN_COMP_MSVC < 1900) || \
        -:  707:  (EIGEN_COMP_ICC && EIGEN_COMP_ICC < 1500) || \
        -:  708:  (EIGEN_COMP_NVCC && EIGEN_COMP_NVCC < 80000) || \
        -:  709:  (EIGEN_COMP_CLANG_STRICT && EIGEN_COMP_CLANG < 390) || \
        -:  710:  (EIGEN_COMP_CLANGAPPLE && EIGEN_COMP_CLANGAPPLE < 9000000) || \
        -:  711:  (EIGEN_COMP_GNUC_STRICT && EIGEN_COMP_GNUC < 510)
        -:  712:#error This compiler appears to be too old to be supported by Eigen
        -:  713:#endif
        -:  714:
        -:  715:// Does the compiler support C99?
        -:  716:// Need to include <cmath> to make sure _GLIBCXX_USE_C99 gets defined
        -:  717:#include <cmath>
        -:  718:#ifndef EIGEN_HAS_C99_MATH
        -:  719:#if ((defined(__STDC_VERSION__) && (__STDC_VERSION__ >= 199901))       \
        -:  720:  || (defined(__GNUC__) && defined(_GLIBCXX_USE_C99)) \
        -:  721:  || (defined(_LIBCPP_VERSION) && !defined(_MSC_VER)) \
        -:  722:  || (EIGEN_COMP_MSVC) || defined(SYCL_DEVICE_ONLY))
        -:  723:  #define EIGEN_HAS_C99_MATH 1
        -:  724:#else
        -:  725:  #define EIGEN_HAS_C99_MATH 0
        -:  726:#endif
        -:  727:#endif
        -:  728:
        -:  729:// Does the compiler support std::hash?
        -:  730:#ifndef EIGEN_HAS_STD_HASH
        -:  731:// The std::hash struct is defined in C++11 but is not labelled as a __device__
        -:  732:// function and is not constexpr, so cannot be used on device.
        -:  733:#if !defined(EIGEN_GPU_COMPILE_PHASE)
        -:  734:#define EIGEN_HAS_STD_HASH 1
        -:  735:#else
        -:  736:#define EIGEN_HAS_STD_HASH 0
        -:  737:#endif
        -:  738:#endif  // EIGEN_HAS_STD_HASH
        -:  739:
        -:  740:#ifndef EIGEN_HAS_STD_INVOKE_RESULT
        -:  741:#if EIGEN_MAX_CPP_VER >= 17 && EIGEN_COMP_CXXVER >= 17
        -:  742:#define EIGEN_HAS_STD_INVOKE_RESULT 1
        -:  743:#else
        -:  744:#define EIGEN_HAS_STD_INVOKE_RESULT 0
        -:  745:#endif
        -:  746:#endif
        -:  747:
        -:  748:#define EIGEN_CONSTEXPR constexpr
        -:  749:
        -:  750:// NOTE: the required Apple's clang version is very conservative
        -:  751://       and it could be that XCode 9 works just fine.
        -:  752:// NOTE: the MSVC version is based on https://en.cppreference.com/w/cpp/compiler_support
        -:  753://       and not tested.
        -:  754:// NOTE: Intel C++ Compiler Classic (icc) Version 19.0 and later supports dynamic allocation
        -:  755://       for over-aligned data, but not in a manner that is compatible with Eigen.
        -:  756://       See https://gitlab.com/libeigen/eigen/-/issues/2575
        -:  757:#ifndef EIGEN_HAS_CXX17_OVERALIGN
        -:  758:#if EIGEN_MAX_CPP_VER>=17 && EIGEN_COMP_CXXVER>=17 && (                 \
        -:  759:           (EIGEN_COMP_MSVC >= 1912)                                    \
        -:  760:        || (EIGEN_GNUC_STRICT_AT_LEAST(7,0,0))                          \
        -:  761:        || (EIGEN_CLANG_STRICT_AT_LEAST(5,0,0))                         \
        -:  762:        || (EIGEN_COMP_CLANGAPPLE && EIGEN_COMP_CLANGAPPLE >= 10000000) \
        -:  763:      ) && !EIGEN_COMP_ICC
        -:  764:#define EIGEN_HAS_CXX17_OVERALIGN 1
        -:  765:#else
        -:  766:#define EIGEN_HAS_CXX17_OVERALIGN 0
        -:  767:#endif
        -:  768:#endif
        -:  769:
        -:  770:#if defined(EIGEN_CUDACC)
        -:  771:  // While available already with c++11, this is useful mostly starting with c++14 and relaxed constexpr rules
        -:  772:  #if defined(__NVCC__)
        -:  773:    // nvcc considers constexpr functions as __host__ __device__ with the option --expt-relaxed-constexpr
        -:  774:    #ifdef __CUDACC_RELAXED_CONSTEXPR__
        -:  775:      #define EIGEN_CONSTEXPR_ARE_DEVICE_FUNC
        -:  776:    #endif
        -:  777:  #elif defined(__clang__) && defined(__CUDA__) && __has_feature(cxx_relaxed_constexpr)
        -:  778:    // clang++ always considers constexpr functions as implicitly __host__ __device__
        -:  779:    #define EIGEN_CONSTEXPR_ARE_DEVICE_FUNC
        -:  780:  #endif
        -:  781:#endif
        -:  782:
        -:  783:// Does the compiler support the __int128 and __uint128_t extensions for 128-bit
        -:  784:// integer arithmetic?
        -:  785://
        -:  786:// Clang and GCC define __SIZEOF_INT128__ when these extensions are supported,
        -:  787:// but we avoid using them in certain cases:
        -:  788://
        -:  789:// * Building using Clang for Windows, where the Clang runtime library has
        -:  790://   128-bit support only on LP64 architectures, but Windows is LLP64.
        -:  791:#ifndef EIGEN_HAS_BUILTIN_INT128
        -:  792:#if defined(__SIZEOF_INT128__) && !(EIGEN_OS_WIN && EIGEN_COMP_CLANG)
        -:  793:#define EIGEN_HAS_BUILTIN_INT128 1
        -:  794:#else
        -:  795:#define EIGEN_HAS_BUILTIN_INT128 0
        -:  796:#endif
        -:  797:#endif
        -:  798:
        -:  799://------------------------------------------------------------------------------------------
        -:  800:// Preprocessor programming helpers
        -:  801://------------------------------------------------------------------------------------------
        -:  802:
        -:  803:// This macro can be used to prevent from macro expansion, e.g.:
        -:  804://   std::max EIGEN_NOT_A_MACRO(a,b)
        -:  805:#define EIGEN_NOT_A_MACRO
        -:  806:
        -:  807:#define EIGEN_DEBUG_VAR(x) std::cerr << #x << " = " << x << std::endl;
        -:  808:
        -:  809:// concatenate two tokens
        -:  810:#define EIGEN_CAT2(a,b) a ## b
        -:  811:#define EIGEN_CAT(a,b) EIGEN_CAT2(a,b)
        -:  812:
        -:  813:#define EIGEN_COMMA ,
        -:  814:
        -:  815:// convert a token to a string
        -:  816:#define EIGEN_MAKESTRING2(a) #a
        -:  817:#define EIGEN_MAKESTRING(a) EIGEN_MAKESTRING2(a)
        -:  818:
        -:  819:// EIGEN_STRONG_INLINE is a stronger version of the inline, using __forceinline on MSVC,
        -:  820:// but it still doesn't use GCC's always_inline. This is useful in (common) situations where MSVC needs forceinline
        -:  821:// but GCC is still doing fine with just inline.
        -:  822:#ifndef EIGEN_STRONG_INLINE
        -:  823:#if (EIGEN_COMP_MSVC || EIGEN_COMP_ICC) && !defined(EIGEN_GPUCC)
        -:  824:#define EIGEN_STRONG_INLINE __forceinline
        -:  825:#else
        -:  826:#define EIGEN_STRONG_INLINE inline
        -:  827:#endif
        -:  828:#endif
        -:  829:
        -:  830:// EIGEN_ALWAYS_INLINE is the strongest, it has the effect of making the function inline and adding every possible
        -:  831:// attribute to maximize inlining. This should only be used when really necessary: in particular,
        -:  832:// it uses __attribute__((always_inline)) on GCC, which most of the time is useless and can severely harm compile times.
        -:  833:// FIXME with the always_inline attribute,
        -:  834:#if EIGEN_COMP_GNUC && !defined(SYCL_DEVICE_ONLY)
        -:  835:#define EIGEN_ALWAYS_INLINE __attribute__((always_inline)) inline
        -:  836:#else
        -:  837:#define EIGEN_ALWAYS_INLINE EIGEN_STRONG_INLINE
        -:  838:#endif
        -:  839:
        -:  840:#if EIGEN_COMP_GNUC
        -:  841:#define EIGEN_DONT_INLINE __attribute__((noinline))
        -:  842:#elif EIGEN_COMP_MSVC
        -:  843:#define EIGEN_DONT_INLINE __declspec(noinline)
        -:  844:#else
        -:  845:#define EIGEN_DONT_INLINE
        -:  846:#endif
        -:  847:
        -:  848:#if EIGEN_COMP_GNUC
        -:  849:#define EIGEN_PERMISSIVE_EXPR __extension__
        -:  850:#else
        -:  851:#define EIGEN_PERMISSIVE_EXPR
        -:  852:#endif
        -:  853:
        -:  854:// GPU stuff
        -:  855:
        -:  856:// Disable some features when compiling with GPU compilers (SYCL/HIPCC)
        -:  857:#if defined(SYCL_DEVICE_ONLY) || defined(EIGEN_HIP_DEVICE_COMPILE)
        -:  858:  // Do not try asserts on device code
        -:  859:  #ifndef EIGEN_NO_DEBUG
        -:  860:  #define EIGEN_NO_DEBUG
        -:  861:  #endif
        -:  862:
        -:  863:  #ifdef EIGEN_INTERNAL_DEBUGGING
        -:  864:  #undef EIGEN_INTERNAL_DEBUGGING
        -:  865:  #endif
        -:  866:#endif
        -:  867:
        -:  868:// No exceptions on device.
        -:  869:#if defined(SYCL_DEVICE_ONLY) || defined(EIGEN_GPU_COMPILE_PHASE)
        -:  870:  #ifdef EIGEN_EXCEPTIONS
        -:  871:  #undef EIGEN_EXCEPTIONS
        -:  872:  #endif
        -:  873:#endif
        -:  874:
        -:  875:#if defined(SYCL_DEVICE_ONLY)
        -:  876:  #ifndef EIGEN_DONT_VECTORIZE
        -:  877:    #define EIGEN_DONT_VECTORIZE
        -:  878:  #endif
        -:  879:  #define EIGEN_DEVICE_FUNC __attribute__((flatten)) __attribute__((always_inline))
        -:  880:// All functions callable from CUDA/HIP code must be qualified with __device__
        -:  881:#elif defined(EIGEN_GPUCC)
        -:  882:    #define EIGEN_DEVICE_FUNC __host__ __device__
        -:  883:#else
