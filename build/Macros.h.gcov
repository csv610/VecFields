        -:  442:  #define EIGEN_OS_QNX 0
        -:  443:#endif
        -:  444:
        -:  445:/// \internal EIGEN_OS_WIN set to 1 if the OS is Windows based
        -:  446:#if defined(_WIN32)
        -:  447:  #define EIGEN_OS_WIN 1
        -:  448:#else
        -:  449:  #define EIGEN_OS_WIN 0
        -:  450:#endif
        -:  451:
        -:  452:/// \internal EIGEN_OS_WIN64 set to 1 if the OS is Windows 64bits
        -:  453:#if defined(_WIN64)
        -:  454:  #define EIGEN_OS_WIN64 1
        -:  455:#else
        -:  456:  #define EIGEN_OS_WIN64 0
        -:  457:#endif
        -:  458:
        -:  459:/// \internal EIGEN_OS_WINCE set to 1 if the OS is Windows CE
        -:  460:#if defined(_WIN32_WCE)
        -:  461:  #define EIGEN_OS_WINCE 1
        -:  462:#else
        -:  463:  #define EIGEN_OS_WINCE 0
        -:  464:#endif
        -:  465:
        -:  466:/// \internal EIGEN_OS_CYGWIN set to 1 if the OS is Windows/Cygwin
        -:  467:#if defined(__CYGWIN__)
        -:  468:  #define EIGEN_OS_CYGWIN 1
        -:  469:#else
        -:  470:  #define EIGEN_OS_CYGWIN 0
        -:  471:#endif
        -:  472:
        -:  473:/// \internal EIGEN_OS_WIN_STRICT set to 1 if the OS is really Windows and not some variants
        -:  474:#if EIGEN_OS_WIN && !( EIGEN_OS_WINCE || EIGEN_OS_CYGWIN )
        -:  475:  #define EIGEN_OS_WIN_STRICT 1
        -:  476:#else
        -:  477:  #define EIGEN_OS_WIN_STRICT 0
        -:  478:#endif
        -:  479:
        -:  480:/// \internal EIGEN_OS_SUN set to __SUNPRO_C if the OS is SUN
        -:  481:// compiler  solaris   __SUNPRO_C
        -:  482:// version   studio
        -:  483:// 5.7       10        0x570
        -:  484:// 5.8       11        0x580
        -:  485:// 5.9       12        0x590
        -:  486:// 5.10	     12.1      0x5100
        -:  487:// 5.11	     12.2      0x5110
        -:  488:// 5.12	     12.3      0x5120
        -:  489:#if (defined(sun) || defined(__sun)) && !(defined(__SVR4) || defined(__svr4__))
        -:  490:  #define EIGEN_OS_SUN __SUNPRO_C
        -:  491:#else
        -:  492:  #define EIGEN_OS_SUN 0
        -:  493:#endif
        -:  494:
        -:  495:/// \internal EIGEN_OS_SOLARIS set to 1 if the OS is Solaris
        -:  496:#if (defined(sun) || defined(__sun)) && (defined(__SVR4) || defined(__svr4__))
        -:  497:  #define EIGEN_OS_SOLARIS 1
        -:  498:#else
        -:  499:  #define EIGEN_OS_SOLARIS 0
        -:  500:#endif
