        -:  968:
        -:  969:// Acts as a barrier preventing operations involving `X` from crossing. This
        -:  970:// occurs, for example, in the fast rounding trick where a magic constant is
        -:  971:// added then subtracted, which is otherwise compiled away with -ffast-math.
        -:  972://
        -:  973:// See bug 1674
        -:  974:#if !defined(EIGEN_OPTIMIZATION_BARRIER)
        -:  975:  #if EIGEN_COMP_GNUC
        -:  976:    // According to https://gcc.gnu.org/onlinedocs/gcc/Constraints.html:
        -:  977:    //   X: Any operand whatsoever.
        -:  978:    //   r: A register operand is allowed provided that it is in a general
        -:  979:    //      register.
        -:  980:    //   g: Any register, memory or immediate integer operand is allowed, except
        -:  981:    //      for registers that are not general registers.
        -:  982:    //   w: (AArch32/AArch64) Floating point register, Advanced SIMD vector
        -:  983:    //      register or SVE vector register.
        -:  984:    //   x: (SSE) Any SSE register.
        -:  985:    //      (AArch64) Like w, but restricted to registers 0 to 15 inclusive.
        -:  986:    //   v: (PowerPC) An Altivec vector register.
        -:  987:    //   wa:(PowerPC) A VSX register.
        -:  988:    //
        -:  989:    // "X" (uppercase) should work for all cases, though this seems to fail for
        -:  990:    // some versions of GCC for arm/aarch64 with
        -:  991:    //   "error: inconsistent operand constraints in an 'asm'"
        -:  992:    // Clang x86_64/arm/aarch64 seems to require "g" to support both scalars and
        -:  993:    // vectors, otherwise
        -:  994:    //   "error: non-trivial scalar-to-vector conversion, possible invalid
        -:  995:    //    constraint for vector type"
        -:  996:    //
        -:  997:    // GCC for ppc64le generates an internal compiler error with x/X/g.
        -:  998:    // GCC for AVX generates an internal compiler error with X.
        -:  999:    //
        -: 1000:    // Tested on icc/gcc/clang for sse, avx, avx2, avx512dq
        -: 1001:    //           gcc for arm, aarch64,
        -: 1002:    //           gcc for ppc64le,
        -: 1003:    // both vectors and scalars.
        -: 1004:    //
        -: 1005:    // Note that this is restricted to plain types - this will not work
        -: 1006:    // directly for std::complex<T>, Eigen::half, Eigen::bfloat16. For these,
        -: 1007:    // you will need to apply to the underlying POD type.
        -: 1008:    #if EIGEN_ARCH_PPC && EIGEN_COMP_GNUC_STRICT
        -: 1009:      // This seems to be broken on clang. Packet4f is loaded into a single
        -: 1010:      //   register rather than a vector, zeroing out some entries. Integer
        -: 1011:      //   types also generate a compile error.
        -: 1012:      #if EIGEN_OS_MAC
        -: 1013:        // General, Altivec for Apple (VSX were added in ISA v2.06):
        -: 1014:        #define EIGEN_OPTIMIZATION_BARRIER(X)  __asm__  ("" : "+r,v" (X));
        -: 1015:      #else
        -: 1016:        // General, Altivec, VSX otherwise:
        -: 1017:        #define EIGEN_OPTIMIZATION_BARRIER(X)  __asm__  ("" : "+r,v,wa" (X));
        -: 1018:      #endif
        -: 1019:    #elif EIGEN_ARCH_ARM_OR_ARM64
        -: 1020:      #ifdef __ARM_FP
        -: 1021:        // General, VFP or NEON.
        -: 1022:        // Clang doesn't like "r",
        -: 1023:        //    error: non-trivial scalar-to-vector conversion, possible invalid
        -: 1024:        //           constraint for vector typ
        -: 1025:        #define EIGEN_OPTIMIZATION_BARRIER(X)  __asm__  ("" : "+g,w" (X));
        -: 1026:      #else
        -: 1027:        // Arm without VFP or NEON.
        -: 1028:        // "w" constraint will not compile.
        -: 1029:        #define EIGEN_OPTIMIZATION_BARRIER(X)  __asm__  ("" : "+g" (X));
        -: 1030:      #endif
        -: 1031:    #elif EIGEN_ARCH_i386_OR_x86_64
        -: 1032:      // General, SSE.
        -: 1033:      #define EIGEN_OPTIMIZATION_BARRIER(X)  __asm__  ("" : "+g,x" (X));
        -: 1034:    #else
        -: 1035:      // Not implemented for other architectures.
        -: 1036:      #define EIGEN_OPTIMIZATION_BARRIER(X)
        -: 1037:    #endif
        -: 1038:  #else
        -: 1039:    // Not implemented for other compilers.
