        -:   24:/** \internal
        -:   25:  * \class FixedInt
        -:   26:  *
        -:   27:  * This class embeds a compile-time integer \c N.
        -:   28:  *
        -:   29:  * It is similar to c++11 std::integral_constant<int,N> but with some additional features
        -:   30:  * such as:
        -:   31:  *  - implicit conversion to int
        -:   32:  *  - arithmetic and some bitwise operators: -, +, *, /, %, &, |
        -:   33:  *  - c++98/14 compatibility with fix<N> and fix<N>() syntax to define integral constants.
        -:   34:  *
        -:   35:  * It is strongly discouraged to directly deal with this class FixedInt. Instances are expected to
        -:   36:  * be created by the user using Eigen::fix<N> or Eigen::fix<N>().
        -:   37:  * \code
        -:   38:  * internal::cleanup_index_type<T>::type
        -:   39:  * internal::cleanup_index_type<T,DynamicKey>::type
        -:   40:  * \endcode
        -:   41:  * where T can a FixedInt<N>, a pointer to function FixedInt<N> (*)(), or numerous other integer-like representations.
        -:   42:  * \c DynamicKey is either Dynamic (default) or DynamicIndex and used to identify true compile-time values.
        -:   43:  *
        -:   44:  * For convenience, you can extract the compile-time value \c N in a generic way using the following helper:
        -:   45:  * \code
        -:   46:  * internal::get_fixed_value<T,DefaultVal>::value
        -:   47:  * \endcode
        -:   48:  * that will give you \c N if T equals FixedInt<N> or FixedInt<N> (*)(), and \c DefaultVal if T does not embed any compile-time value (e.g., T==int).
        -:   49:  *
        -:   50:  * \sa fix<N>, class VariableAndFixedInt
        -:   51:  */
        -:   52:template<int N> class FixedInt
        -:   53:{
        -:   54:public:
        -:   55:  static const int value = N;
        -:   56:  EIGEN_CONSTEXPR operator int() const { return value; }
        -:   57:  
        -:   58:  EIGEN_CONSTEXPR
        -:   59:  FixedInt() = default;
        -:   60:  
        -:   61:  EIGEN_CONSTEXPR
        -:   62:  FixedInt(std::integral_constant<int,N>) {}
        -:   63:  
        -:   64:  EIGEN_CONSTEXPR
        -:   65:  FixedInt( VariableAndFixedInt<N> other) {
        -:   66:    #ifndef EIGEN_INTERNAL_DEBUGGING
        -:   67:    EIGEN_UNUSED_VARIABLE(other);
        -:   68:    #endif
        -:   69:    eigen_internal_assert(int(other)==N);
        -:   70:  }
        -:   71:
        -:   72:  EIGEN_CONSTEXPR
