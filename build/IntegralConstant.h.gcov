        -:  167:// Cleanup integer/FixedInt/VariableAndFixedInt/etc types:
        -:  168:
        -:  169:// By default, no cleanup:
        -:  170:template<typename T, int DynamicKey=Dynamic, typename EnableIf=void> struct cleanup_index_type { typedef T type; };
        -:  171:
        -:  172:// Convert any integral type (e.g., short, int, unsigned int, etc.) to Eigen::Index
        -:  173:template<typename T, int DynamicKey> struct cleanup_index_type<T,DynamicKey,std::enable_if_t<internal::is_integral<T>::value>> { typedef Index type; };
        -:  174:
        -:  175:// If VariableAndFixedInt does not match DynamicKey, then we turn it to a pure compile-time value:
        -:  176:template<int N, int DynamicKey> struct cleanup_index_type<VariableAndFixedInt<N>, DynamicKey> { typedef FixedInt<N> type; };
        -:  177:// If VariableAndFixedInt matches DynamicKey, then we turn it to a pure runtime-value (aka Index):
        -:  178:template<int DynamicKey> struct cleanup_index_type<VariableAndFixedInt<DynamicKey>, DynamicKey> { typedef Index type; };
        -:  179:
        -:  180:template<int N, int DynamicKey> struct cleanup_index_type<std::integral_constant<int,N>, DynamicKey> { typedef FixedInt<N> type; };
        -:  181:
        -:  182:} // end namespace internal
