        -:  101:  FixedInt<N&M> operator&( FixedInt<M>) const { return FixedInt<N&M>(); }
        -:  102:
        -:  103:  // Needed in C++14 to allow fix<N>():
        1:  104:  EIGEN_CONSTEXPR FixedInt operator() () const { return *this; }
