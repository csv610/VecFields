        -:  109:/** \internal
        -:  110:  * \class VariableAndFixedInt
        -:  111:  *
        -:  112:  * This class embeds both a compile-time integer \c N and a runtime integer.
        -:  113:  * Both values are supposed to be equal unless the compile-time value \c N has a special
        -:  114:  * value meaning that the runtime-value should be used. Depending on the context, this special
        -:  115:  * value can be either Eigen::Dynamic (for positive quantities) or Eigen::DynamicIndex (for
        -:  116:  * quantities that can be negative).
        -:  117:  *
        -:  118:  * It is the return-type of the function Eigen::fix<N>(int), and most of the time this is the only
        -:  119:  * way it is used. It is strongly discouraged to directly deal with instances of VariableAndFixedInt.
        -:  120:  * Indeed, in order to write generic code, it is the responsibility of the callee to properly convert
        -:  121:  * it to either a true compile-time quantity (i.e. a FixedInt<N>), or to a runtime quantity (e.g., an Index)
        -:  122:  * using the following generic helper:
        -:  123:  * \code
        -:  124:  * internal::cleanup_index_type<T>::type
        -:  125:  * internal::cleanup_index_type<T,DynamicKey>::type
        -:  126:  * \endcode
        -:  127:  * where T can be a template instantiation of VariableAndFixedInt or numerous other integer-like representations.
        -:  128:  * \c DynamicKey is either Dynamic (default) or DynamicIndex and used to identify true compile-time values.
        -:  129:  *
        -:  130:  * For convenience, you can also extract the compile-time value \c N using the following helper:
        -:  131:  * \code
        -:  132:  * internal::get_fixed_value<T,DefaultVal>::value
        -:  133:  * \endcode
        -:  134:  * that will give you \c N if T equals VariableAndFixedInt<N>, and \c DefaultVal if T does not embed any compile-time value (e.g., T==int).
        -:  135:  *
        -:  136:  * \sa fix<N>(int), class FixedInt
        -:  137:  */
        -:  138:template<int N> class VariableAndFixedInt
        -:  139:{
        -:  140:public:
        -:  141:  static const int value = N;
        -:  142:  operator int() const { return m_value; }
        -:  143:  VariableAndFixedInt(int val) { m_value = val; }
        -:  144:protected:
        -:  145:  int m_value;
        -:  146:};
        -:  147:
        -:  148:template<typename T, int Default=Dynamic> struct get_fixed_value {
        -:  149:  static const int value = Default;
        -:  150:};
        -:  151:
        -:  152:template<int N,int Default> struct get_fixed_value<FixedInt<N>,Default> {
        -:  153:  static const int value = N;
        -:  154:};
        -:  155:
        -:  156:template<int N,int Default> struct get_fixed_value<VariableAndFixedInt<N>,Default> {
        -:  157:  static const int value = N ;
        -:  158:};
        -:  159:
        -:  160:template<typename T, int N, int Default>
        -:  161:struct get_fixed_value<variable_if_dynamic<T,N>,Default> {
        -:  162:  static const int value = N;
        -:  163:};
