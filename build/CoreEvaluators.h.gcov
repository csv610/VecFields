        -:   29:
        -:   30:// This class returns the evaluator shape from the expression storage kind.
        -:   31:// It can be Dense, Sparse, Triangular, Diagonal, SelfAdjoint, Band, etc.
        -:   32:template<typename StorageKind> struct storage_kind_to_shape;
        -:   33:
        -:   34:template<> struct storage_kind_to_shape<Dense>                  { typedef DenseShape Shape;           };
        -:   35:template<> struct storage_kind_to_shape<SolverStorage>          { typedef SolverShape Shape;           };
