        -:   82:// promote_scalar_arg is an helper used in operation between an expression and a scalar, like:
        -:   83://    expression * scalar
        -:   84:// Its role is to determine how the type T of the scalar operand should be promoted given the scalar type ExprScalar of the given expression.
        -:   85:// The IsSupported template parameter must be provided by the caller as: internal::has_ReturnType<ScalarBinaryOpTraits<ExprScalar,T,op> >::value using the proper order for ExprScalar and T.
        -:   86:// Then the logic is as follows:
        -:   87://  - if the operation is natively supported as defined by IsSupported, then the scalar type is not promoted, and T is returned.
        -:   88://  - otherwise, NumTraits<ExprScalar>::Literal is returned if T is implicitly convertible to NumTraits<ExprScalar>::Literal AND that this does not imply a float to integer conversion.
        -:   89://  - otherwise, ExprScalar is returned if T is implicitly convertible to ExprScalar AND that this does not imply a float to integer conversion.
        -:   90://  - In all other cases, the promoted type is not defined, and the respective operation is thus invalid and not available (SFINAE).
        -:   91:template<typename ExprScalar,typename T, bool IsSupported>
        -:   92:struct promote_scalar_arg;
        -:   93:
        -:   94:template<typename S,typename T>
        -:   95:struct promote_scalar_arg<S,T,true>
        -:   96:{
        -:   97:  typedef T type;
        -:   98:};
        -:   99:
        -:  100:// Recursively check safe conversion to PromotedType, and then ExprScalar if they are different.
        -:  101:template<typename ExprScalar,typename T,typename PromotedType,
        -:  102:  bool ConvertibleToLiteral = internal::is_convertible<T,PromotedType>::value,
        -:  103:  bool IsSafe = NumTraits<T>::IsInteger || !NumTraits<PromotedType>::IsInteger>
        -:  104:struct promote_scalar_arg_unsupported;
        -:  105:
        -:  106:// Start recursion with NumTraits<ExprScalar>::Literal
        -:  107:template<typename S,typename T>
        -:  108:struct promote_scalar_arg<S,T,false> : promote_scalar_arg_unsupported<S,T,typename NumTraits<S>::Literal> {};
        -:  109:
        -:  110:// We found a match!
        -:  111:template<typename S,typename T, typename PromotedType>
        -:  112:struct promote_scalar_arg_unsupported<S,T,PromotedType,true,true>
        -:  113:{
        -:  114:  typedef PromotedType type;
        -:  115:};
        -:  116:
        -:  117:// No match, but no real-to-integer issues, and ExprScalar and current PromotedType are different,
        -:  118:// so let's try to promote to ExprScalar
        -:  119:template<typename ExprScalar,typename T, typename PromotedType>
        -:  120:struct promote_scalar_arg_unsupported<ExprScalar,T,PromotedType,false,true>
        -:  121:   : promote_scalar_arg_unsupported<ExprScalar,T,ExprScalar>
        -:  122:{};
        -:  123:
        -:  124:// Unsafe real-to-integer, let's stop.
        -:  125:template<typename S,typename T, typename PromotedType, bool ConvertibleToLiteral>
        -:  126:struct promote_scalar_arg_unsupported<S,T,PromotedType,ConvertibleToLiteral,false> {};
        -:  127:
        -:  128:// T is not even convertible to ExprScalar, let's stop.
        -:  129:template<typename S,typename T>
        -:  130:struct promote_scalar_arg_unsupported<S,T,S,false,true> {};
