        -:  863:/** \class ScalarBinaryOpTraits
        -:  864:  * \ingroup Core_Module
        -:  865:  *
        -:  866:  * \brief Determines whether the given binary operation of two numeric types is allowed and what the scalar return type is.
        -:  867:  *
        -:  868:  * This class permits to control the scalar return type of any binary operation performed on two different scalar types through (partial) template specializations.
        -:  869:  *
        -:  870:  * For instance, let \c U1, \c U2 and \c U3 be three user defined scalar types for which most operations between instances of \c U1 and \c U2 returns an \c U3.
        -:  871:  * You can let %Eigen knows that by defining:
        -:  872:    \code
        -:  873:    template<typename BinaryOp>
        -:  874:    struct ScalarBinaryOpTraits<U1,U2,BinaryOp> { typedef U3 ReturnType;  };
        -:  875:    template<typename BinaryOp>
        -:  876:    struct ScalarBinaryOpTraits<U2,U1,BinaryOp> { typedef U3 ReturnType;  };
        -:  877:    \endcode
        -:  878:  * You can then explicitly disable some particular operations to get more explicit error messages:
        -:  879:    \code
        -:  880:    template<>
        -:  881:    struct ScalarBinaryOpTraits<U1,U2,internal::scalar_max_op<U1,U2> > {};
        -:  882:    \endcode
        -:  883:  * Or customize the return type for individual operation:
        -:  884:    \code
        -:  885:    template<>
        -:  886:    struct ScalarBinaryOpTraits<U1,U2,internal::scalar_sum_op<U1,U2> > { typedef U1 ReturnType; };
        -:  887:    \endcode
        -:  888:  *
        -:  889:  * By default, the following generic combinations are supported:
        -:  890:  <table class="manual">
        -:  891:  <tr><th>ScalarA</th><th>ScalarB</th><th>BinaryOp</th><th>ReturnType</th><th>Note</th></tr>
        -:  892:  <tr            ><td>\c T </td><td>\c T </td><td>\c * </td><td>\c T </td><td></td></tr>
        -:  893:  <tr class="alt"><td>\c NumTraits<T>::Real </td><td>\c T </td><td>\c * </td><td>\c T </td><td>Only if \c NumTraits<T>::IsComplex </td></tr>
        -:  894:  <tr            ><td>\c T </td><td>\c NumTraits<T>::Real </td><td>\c * </td><td>\c T </td><td>Only if \c NumTraits<T>::IsComplex </td></tr>
        -:  895:  </table>
        -:  896:  *
        -:  897:  * \sa CwiseBinaryOp
        -:  898:  */
        -:  899:template<typename ScalarA, typename ScalarB, typename BinaryOp=internal::scalar_product_op<ScalarA,ScalarB> >
        -:  900:struct ScalarBinaryOpTraits
        -:  901:#ifndef EIGEN_PARSED_BY_DOXYGEN
        -:  902:  // for backward compatibility, use the hints given by the (deprecated) internal::scalar_product_traits class.
        -:  903:  : internal::scalar_product_traits<ScalarA,ScalarB>
        -:  904:#endif // EIGEN_PARSED_BY_DOXYGEN
        -:  905:{};
        -:  906:
        -:  907:template<typename T, typename BinaryOp>
        -:  908:struct ScalarBinaryOpTraits<T,T,BinaryOp>
        -:  909:{
        -:  910:  typedef T ReturnType;
        -:  911:};
        -:  912:
        -:  913:template <typename T, typename BinaryOp>
        -:  914:struct ScalarBinaryOpTraits<T, typename NumTraits<std::enable_if_t<NumTraits<T>::IsComplex,T>>::Real, BinaryOp>
        -:  915:{
        -:  916:  typedef T ReturnType;
        -:  917:};
        -:  918:template <typename T, typename BinaryOp>
        -:  919:struct ScalarBinaryOpTraits<typename NumTraits<std::enable_if_t<NumTraits<T>::IsComplex,T>>::Real, T, BinaryOp>
        -:  920:{
        -:  921:  typedef T ReturnType;
        -:  922:};
        -:  923:
        -:  924:// For Matrix * Permutation
        -:  925:template<typename T, typename BinaryOp>
        -:  926:struct ScalarBinaryOpTraits<T,void,BinaryOp>
        -:  927:{
        -:  928:  typedef T ReturnType;
        -:  929:};
        -:  930:
        -:  931:// For Permutation * Matrix
        -:  932:template<typename T, typename BinaryOp>
        -:  933:struct ScalarBinaryOpTraits<void,T,BinaryOp>
        -:  934:{
        -:  935:  typedef T ReturnType;
        -:  936:};
        -:  937:
        -:  938:// for Permutation*Permutation
        -:  939:template<typename BinaryOp>
        -:  940:struct ScalarBinaryOpTraits<void,void,BinaryOp>
        -:  941:{
        -:  942:  typedef void ReturnType;
        -:  943:};
        -:  944:
        -:  945:// We require Lhs and Rhs to have "compatible" scalar types.
        -:  946:// It is tempting to always allow mixing different types but remember that this is often impossible in the vectorized paths.
        -:  947:// So allowing mixing different types gives very unexpected errors when enabling vectorization, when the user tries to
        -:  948:// add together a float matrix and a double matrix.
        -:  949:#define EIGEN_CHECK_BINARY_COMPATIBILIY(BINOP,LHS,RHS) \
        -:  950:  EIGEN_STATIC_ASSERT((Eigen::internal::has_ReturnType<ScalarBinaryOpTraits<LHS, RHS,BINOP> >::value), \
        -:  951:    YOU_MIXED_DIFFERENT_NUMERIC_TYPES__YOU_NEED_TO_USE_THE_CAST_METHOD_OF_MATRIXBASE_TO_CAST_NUMERIC_TYPES_EXPLICITLY)
        -:  952:
        -:  953:} // end namespace Eigen
        -:  954:
        -:  955:#endif // EIGEN_XPRHELPER_H
