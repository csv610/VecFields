        -:  456:/** \internal The reference selector for template expressions. The idea is that we don't
        -:  457:  * need to use references for expressions since they are light weight proxy
        -:  458:  * objects which should generate no copying overhead. */
        -:  459:template <typename T>
        -:  460:struct ref_selector
        -:  461:{
        -:  462:  typedef std::conditional_t<
        -:  463:    bool(traits<T>::Flags & NestByRefBit),
        -:  464:    T const&,
        -:  465:    const T
        -:  466:  > type;
        -:  467:
        -:  468:  typedef std::conditional_t<
        -:  469:    bool(traits<T>::Flags & NestByRefBit),
        -:  470:    T &,
        -:  471:    T
        -:  472:  > non_const_type;
        -:  473:};
        -:  474:
        -:  475:/** \internal Adds the const qualifier on the value-type of T2 if and only if T1 is a const type */
        -:  476:template<typename T1, typename T2>
        -:  477:struct transfer_constness
        -:  478:{
        -:  479:  typedef std::conditional_t<
        -:  480:    bool(internal::is_const<T1>::value),
        -:  481:    add_const_on_value_type_t<T2>,
        -:  482:    T2
        -:  483:  > type;
        -:  484:};
        -:  485:
        -:  486:
        -:  487:// However, we still need a mechanism to detect whether an expression which is evaluated multiple time
        -:  488:// has to be evaluated into a temporary.
        -:  489:// That's the purpose of this new nested_eval helper:
        -:  490:/** \internal Determines how a given expression should be nested when evaluated multiple times.
        -:  491:  * For example, when you do a * (b+c), Eigen will determine how the expression b+c should be
        -:  492:  * evaluated into the bigger product expression. The choice is between nesting the expression b+c as-is, or
        -:  493:  * evaluating that expression b+c into a temporary variable d, and nest d so that the resulting expression is
        -:  494:  * a*d. Evaluating can be beneficial for example if every coefficient access in the resulting expression causes
        -:  495:  * many coefficient accesses in the nested expressions -- as is the case with matrix product for example.
        -:  496:  *
        -:  497:  * \tparam T the type of the expression being nested.
        -:  498:  * \tparam n the number of coefficient accesses in the nested expression for each coefficient access in the bigger expression.
        -:  499:  * \tparam PlainObject the type of the temporary if needed.
        -:  500:  */
        -:  501:template<typename T, int n, typename PlainObject = typename plain_object_eval<T>::type> struct nested_eval
        -:  502:{
        -:  503:  enum {
        -:  504:    ScalarReadCost = NumTraits<typename traits<T>::Scalar>::ReadCost,
        -:  505:    CoeffReadCost = evaluator<T>::CoeffReadCost,  // NOTE What if an evaluator evaluate itself into a temporary?
        -:  506:                                                  //      Then CoeffReadCost will be small (e.g., 1) but we still have to evaluate, especially if n>1.
        -:  507:                                                  //      This situation is already taken care by the EvalBeforeNestingBit flag, which is turned ON
        -:  508:                                                  //      for all evaluator creating a temporary. This flag is then propagated by the parent evaluators.
        -:  509:                                                  //      Another solution could be to count the number of temps?
        -:  510:    NAsInteger = n == Dynamic ? HugeCost : n,
        -:  511:    CostEval   = (NAsInteger+1) * ScalarReadCost + CoeffReadCost,
        -:  512:    CostNoEval = NAsInteger * CoeffReadCost,
        -:  513:    Evaluate = (int(evaluator<T>::Flags) & EvalBeforeNestingBit) || (int(CostEval) < int(CostNoEval))
        -:  514:  };
        -:  515:
        -:  516:  typedef std::conditional_t<Evaluate, PlainObject, typename ref_selector<T>::type> type;
        -:  517:};
