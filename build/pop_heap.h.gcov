        -:   66:
        -:   67:  typename iterator_traits<_RandomAccessIterator>::difference_type __len = __last - __first;
        -:   68:  std::__pop_heap<_ClassicAlgPolicy>(std::move(__first), std::move(__last), __comp, __len);
