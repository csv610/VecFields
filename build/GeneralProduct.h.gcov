        -:  408:  enum {
        -:  409:    ProductIsValid =  Derived::ColsAtCompileTime==Dynamic
        -:  410:                   || OtherDerived::RowsAtCompileTime==Dynamic
        -:  411:                   || int(Derived::ColsAtCompileTime)==int(OtherDerived::RowsAtCompileTime),
