        -:   15:namespace directional {
        -:   16:
        -:   17://Computing a matrix that transforms an xyzxyz extrinsic field field in raw format to an xyxyxy intrinsic vector.
        -:   18://Note that this operation is lossy: any normal components in the extrinsic field will be lost.
        -:   19://Input:
        -:   20://  Mesh:     a triangle mesh
        -:   21://  N:        the degree of the field
        -:   22://  d:        the polynomial degree (inactive)
        -:   23://Output:
        -:   24://  A 2N x 3N conversion matrix.
        -:   25:
        -:   26:template<typename NumberType>
    #####:   27:Eigen::SparseMatrix<NumberType> face_extrinsic_to_intrinsic_matrix_2D(const TriMesh& mesh,
        -:   28:                                                                      const int N = 1,
        -:   29:                                                                      const int d = 1) {
        -:   30:    
    #####:   31:    assert(d == 1 && "This method is currently defined only for d==1");
    #####:   32:    Eigen::SparseMatrix<NumberType> EI(2 * mesh.F.rows(), 3 * mesh.F.rows());
    #####:   33:    std::vector<Eigen::Triplet<NumberType>> EITris;
    #####:   34:    for (int i = 0; i < mesh.F.rows(); i++) {
    #####:   35:        EITris.push_back(Eigen::Triplet<NumberType>(2 * i, 3 * i, mesh.FBx(i, 0)));
    #####:   36:        EITris.push_back(Eigen::Triplet<NumberType>(2 * i, 3 * i + 1, mesh.FBx(i, 1)));
    #####:   37:        EITris.push_back(Eigen::Triplet<NumberType>(2 * i, 3 * i + 2, mesh.FBx(i, 2)));
    #####:   38:        EITris.push_back(Eigen::Triplet<NumberType>(2 * i + 1, 3 * i, mesh.FBy(i, 0)));
    #####:   39:        EITris.push_back(Eigen::Triplet<NumberType>(2 * i + 1, 3 * i + 1, mesh.FBy(i, 1)));
    #####:   40:        EITris.push_back(Eigen::Triplet<NumberType>(2 * i + 1, 3 * i + 2, mesh.FBy(i, 2)));
    #####:   41:    }
    #####:   42:    EI.setFromTriplets(EITris.begin(), EITris.end());
    #####:   43:    return (N == 1 ? EI : directional::single_to_N_matrix(EI, N, 2, 3));
    #####:   44:}
        -:   45:
        -:   46://This is the opposite matrix. Note that since extrinsic to intrinsic is lossy, it's just the adjoint of the above matrix.
        -:   47:template<typename NumberType>
    #####:   48:Eigen::SparseMatrix<NumberType> face_intrinsic_to_extrinsic_matrix_2D(const TriMesh& mesh,
        -:   49:                                                                      const int N = 1,
        -:   50:                                                                      const int d = 1) {
    #####:   51:    assert(d == 1 && "This method is currently defined only for d==1");
    #####:   52:    return face_extrinsic_to_intrinsic_matrix_2D<NumberType>(mesh, N, d).adjoint();
    #####:   53:}
        -:   54:}
